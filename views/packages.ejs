<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('partials/head') %>
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-900">
    <%- include('partials/header') %>
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <section class="rounded-[2rem] bg-white border border-slate-200 shadow-sm p-10 mb-10">
        <p class="text-sm uppercase tracking-[0.28em] font-semibold text-sky-600">Tour Packages</p>
        <h1 class="mt-4 text-4xl font-semibold tracking-tight text-slate-900">Curated itineraries for every traveler</h1>
        <p class="mt-4 max-w-3xl text-slate-600">Browse confirmed tour packages that include states, cities, attractions and activities based on their itinerary priority.</p>
      </section>
      <section class="grid gap-6 lg:grid-cols-3">
        <% packages.forEach(pkg => { %>
          <article class="group overflow-hidden rounded-[1.75rem] border border-slate-200 bg-white shadow-sm transition duration-200 hover:-translate-y-1 hover:shadow-lg">
            <a href="/packages/<%= pkg.slug %>" class="block">
              <div class="h-64 bg-cover bg-center" style="background-image:url('<%= pkg.heroImage || '/images/placeholder.jpg' %>')"></div>
            </a>
            <div class="p-6">
              <p class="text-sm uppercase tracking-[0.24em] text-sky-600">Package</p>
              <h2 class="mt-3 text-2xl font-semibold text-slate-900"><a href="/packages/<%= pkg.slug %>" class="hover:text-sky-600"><%= pkg.name %></a></h2>
              <p class="mt-4 text-sm leading-6 text-slate-600"><%= pkg.summary || pkg.description?.slice(0, 120) || 'A curated travel package with locations and activities.' %></p>
              <div class="mt-5 grid gap-2 text-sm text-slate-500">
                <% if (pkg.duration) { %>
                  <span class="inline-flex items-center rounded-full bg-slate-100 px-3 py-1"><strong class="mr-2 text-slate-700">Duration:</strong> <%= pkg.duration %></span>
                <% } %>
                <% if (pkg.price) { %>
                  <span class="inline-flex items-center rounded-full bg-slate-100 px-3 py-1"><strong class="mr-2 text-slate-700">Price:</strong> <%= pkg.price %></span>
                <% } %>
                <span class="inline-flex items-center rounded-full bg-slate-100 px-3 py-1"><strong class="mr-2 text-slate-700">Itinerary:</strong> <%= pkg.itineraryCountries?.length || 0 %> countries, <%= pkg.itineraryStates?.length || 0 %> states, <%= pkg.itineraryCities?.length || 0 %> cities</span>
              </div>
            </div>
          </article>
        <% }) %>
      </section>
      <%- include('partials/pagination', { pagination }) %>
    </main>
    <%- include('partials/footer') %>
  </body>
</html>
