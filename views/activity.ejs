<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('partials/head') %>
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-900">
    <%- include('partials/header') %>
    <main class="space-y-12">
      <section class="relative overflow-hidden">
        <div class="absolute inset-0 bg-slate-950/45"></div>
        <div class="h-[420px] bg-cover bg-center" style="background-image:url('<%= activity.heroImage || '/images/placeholder.jpg' %>')"></div>
        <div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-20">
          <div class="max-w-3xl text-white">
            <p class="text-sm uppercase tracking-[0.28em] text-sky-300 font-semibold"><%= activity.category || 'Activity' %></p>
            <h1 class="mt-4 text-4xl font-semibold tracking-tight"><%= activity.name %></h1>
            <p class="mt-6 text-lg leading-8 text-slate-200"><%= activity.summary || activity.description?.slice(0, 160) || 'Discover this activity and book your experience.' %></p>
          </div>
        </div>
      </section>
      <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid gap-8 lg:grid-cols-[1.5fr_0.5fr] items-start">
          <div class="rounded-[1.75rem] bg-white border border-slate-200 p-10 shadow-sm">
            <h2 class="text-3xl font-semibold text-slate-900">Overview</h2>
            <p class="mt-4 text-slate-600"><%= activity.description || 'This activity page is built from admin-managed content for traveler planning and inspiration.' %></p>
          </div>
          <div class="rounded-[1.75rem] bg-white border border-slate-200 p-8 shadow-sm">
            <div class="space-y-4 text-slate-700">
              <% if (activity.country) { %>
                <a href="/countries/<%= activity.country.slug %>" class="block rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-900 transition hover:bg-slate-100">Country: <%= activity.country.name %></a>
              <% } %>
              <% if (activity.state) { %>
                <a href="/states/<%= activity.state.slug %>" class="block rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-900 transition hover:bg-slate-100">State: <%= activity.state.name %></a>
              <% } %>
              <% if (activity.city) { %>
                <a href="/cities/<%= activity.city.slug %>" class="block rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-900 transition hover:bg-slate-100">City: <%= activity.city.name %></a>
              <% } %>
            </div>
          </div>
        </div>
      </section>
    </main>
    <%- include('partials/footer') %>
  </body>
</html>
