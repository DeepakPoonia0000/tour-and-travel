<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('partials/head') %>
    <style>
      .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      }

      .hero-shadow {
        text-shadow: 0 4px 12px rgba(0, 0, 0, 0.3);
      }
    </style>
  </head>
  <body class="bg-surface font-body text-on-surface antialiased">
    <%- include('partials/header') %>
    <%
      const heroImage = pkg.heroImage || '/images/placeholder.jpg';
      const introImage = pkg.introImage || itineraryCities[0]?.heroImage || itineraryAttractions[0]?.heroImage || heroImage;
      const heroEyebrow = pkg.heroEyebrow || `${pkg.duration || 'Curated'} Expedition`;
      const heroLocation = pkg.heroLocation || itineraryCities.map((item) => item.name).slice(0, 3).join(' • ') || itineraryStates.map((item) => item.name).slice(0, 3).join(' • ');
      const heroSeason = pkg.heroSeason || 'All Year Round';
      const introHeading = pkg.introHeading || pkg.summary || `A curated journey through ${pkg.name}.`;
      const introBody = pkg.introBody || pkg.description || 'This package brings together the itinerary, destination highlights, and travel planning details managed from admin.';
      const testimonialQuote = pkg.testimonialQuote || 'A thoughtfully paced itinerary with standout local moments and polished logistics throughout.';
      const testimonialAuthor = pkg.testimonialAuthor || 'Tour & Travel Guest';
      const itineraryDays = Array.isArray(pkg.itineraryDays) && pkg.itineraryDays.length
        ? pkg.itineraryDays
        : [
          { dayLabel: 'Day 1', title: itineraryCities[0]?.name || 'Arrival & Orientation', description: pkg.summary || 'Settle into the trip with a curated arrival and the first signature experience.' },
          { dayLabel: 'Day 2', title: itineraryAttractions[0]?.name || 'Landmark Highlights', description: 'Continue through the route with destination-led sightseeing and immersive local details.' },
          { dayLabel: 'Day 3', title: itineraryActivities[0]?.name || 'Experiences & Local Flavor', description: 'Balance iconic stops with activities, culture, and room for discovery.' }
        ];
      const pricingHeading = pkg.pricingHeading || 'Choose Your Experience Level';
      const pricingDescription = pkg.pricingDescription || 'Tailored service tiers to match your travel philosophy.';
      const pricingTiers = Array.isArray(pkg.pricingTiers) && pkg.pricingTiers.length
        ? pkg.pricingTiers
        : [
          { eyebrow: 'The Explorer', name: 'Budget', price: pkg.price || '$899', priceSuffix: '/ person', features: ['Comfort stays', 'Daily breakfast', 'Shared sightseeing', 'Planned transfers'], buttonLabel: 'Inquire Now', isFeatured: false },
          { eyebrow: 'The Connoisseur', name: 'Standard', price: pkg.price || '$1,499', priceSuffix: '/ person', features: ['Premium stays', 'Selected meals', 'Private guided tours', 'Private vehicle'], buttonLabel: 'Book Preferred', isFeatured: true },
          { eyebrow: 'The Aristocrat', name: 'Luxury', price: pkg.price || '$2,850', priceSuffix: '/ person', features: ['Luxury stays', 'Fine dining inclusions', 'Personal assistance', 'Premium transport'], buttonLabel: 'Request Premium', isFeatured: false }
        ];
      const inclusions = Array.isArray(pkg.inclusions) && pkg.inclusions.length
        ? pkg.inclusions
        : ['Accommodation in curated hotels.', 'Guided sightseeing on the core route.', 'Planned in-destination transport.'];
      const exclusions = Array.isArray(pkg.exclusions) && pkg.exclusions.length
        ? pkg.exclusions
        : ['International airfare.', 'Travel insurance.', 'Personal expenses and optional add-ons.'];
      const reviews = Array.isArray(pkg.reviews) && pkg.reviews.length
        ? pkg.reviews
        : [
          { name: 'Sarah Mitchell', meta: 'Visited recently', quote: 'The itinerary felt smooth, elevated, and incredibly well paced.', image: heroImage },
          { name: 'David Chen', meta: 'Couple traveler', quote: 'A strong mix of major highlights and quieter local experiences.', image: introImage },
          { name: 'Priya Sharma', meta: 'Solo traveler', quote: 'I felt supported throughout, and the experience stayed polished from start to finish.', image: heroImage }
        ];
      const floatingButton = pkg.bookingButtonLabel || 'Book Now';
      const floatingSecondaryButton = pkg.bookingSecondaryLabel || 'Save to Itinerary';
      const floatingPriceSuffix = pkg.bookingPriceLabel || '/ traveler';
    %>
    <main class="pt-20">
      <section class="relative h-[870px] overflow-hidden">
        <div class="absolute inset-0">
          <img src="<%= heroImage %>" alt="<%= pkg.name %>" class="h-full w-full object-cover" />
          <div class="absolute inset-0 bg-gradient-to-b from-black/10 via-black/20 to-surface"></div>
        </div>
        <div class="relative z-10 mx-auto flex h-full max-w-7xl flex-col items-center justify-center px-4 text-center sm:px-6 lg:px-8">
          <span class="hero-shadow text-sm font-bold uppercase tracking-[0.3em] text-white"><%= heroEyebrow %></span>
          <h1 class="hero-shadow mt-4 font-serif text-5xl font-bold text-white sm:text-6xl lg:text-7xl"><%= pkg.name %></h1>
          <div class="hero-shadow mt-6 flex flex-wrap items-center justify-center gap-6 text-sm font-medium text-white sm:text-base">
            <% if (heroLocation) { %>
              <span class="inline-flex items-center gap-2">
                <span class="material-symbols-outlined text-secondary">location_on</span>
                <span><%= heroLocation %></span>
              </span>
            <% } %>
            <% if (heroSeason) { %>
              <span class="inline-flex items-center gap-2">
                <span class="material-symbols-outlined text-secondary">calendar_today</span>
                <span><%= heroSeason %></span>
              </span>
            <% } %>
          </div>
        </div>
      </section>

      <section class="mx-auto max-w-7xl px-4 py-24 sm:px-6 lg:px-8">
        <div class="grid items-center gap-16 lg:grid-cols-12">
          <div class="lg:col-span-7">
            <h2 class="font-serif text-4xl leading-tight text-primary"><%= introHeading %></h2>
            <div class="mt-8 space-y-6 text-lg leading-8 text-slate-600">
              <% introBody.split('\n').filter(Boolean).forEach((paragraph) => { %>
                <p><%= paragraph %></p>
              <% }) %>
            </div>
          </div>
          <div class="relative lg:col-span-5">
            <div class="overflow-hidden rounded-[1.75rem] shadow-2xl lg:rotate-2">
              <img src="<%= introImage %>" alt="<%= pkg.name %>" class="h-96 w-full object-cover" />
            </div>
            <div class="absolute -bottom-8 -left-2 max-w-xs rounded-[1.25rem] border border-slate-200 bg-white p-6 shadow-xl sm:-left-8">
              <p class="font-serif text-lg italic text-primary"><%= testimonialQuote %></p>
              <p class="mt-4 text-sm font-bold uppercase tracking-[0.18em] text-secondary"><%= testimonialAuthor %></p>
            </div>
          </div>
        </div>
      </section>

      <section class="bg-surface2 py-24">
        <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
          <h3 class="text-center font-serif text-3xl text-primary">The Itinerary</h3>
          <div class="mt-16 space-y-12">
            <% itineraryDays.forEach((item, index) => { %>
              <div class="flex gap-6 sm:gap-8">
                <div class="flex flex-col items-center">
                  <div class="flex h-12 w-12 items-center justify-center rounded-full bg-primary text-sm font-bold text-white"><%= index + 1 %></div>
                  <% if (index !== itineraryDays.length - 1) { %>
                    <div class="mt-4 w-px flex-1 bg-slate-300"></div>
                  <% } %>
                </div>
                <div class="pb-8">
                  <span class="text-xs font-bold uppercase tracking-[0.22em] text-secondary"><%= item.dayLabel || `Day ${index + 1}` %></span>
                  <h4 class="mt-2 font-serif text-2xl text-slate-900"><%= item.title || 'Itinerary highlight' %></h4>
                  <p class="mt-4 leading-8 text-slate-600"><%= item.description || 'Details for this part of the package can be added from admin.' %></p>
                </div>
              </div>
            <% }) %>
          </div>
        </div>
      </section>

      <section class="mx-auto max-w-7xl px-4 py-24 sm:px-6 lg:px-8">
        <div class="mb-16 text-center">
          <h3 class="font-serif text-4xl text-primary"><%= pricingHeading %></h3>
          <p class="mt-4 text-slate-600"><%= pricingDescription %></p>
        </div>
        <div class="grid gap-8 md:grid-cols-3">
          <% pricingTiers.forEach((tier) => { %>
            <article class="<%= tier.isFeatured ? 'scale-[1.02] bg-primary text-white shadow-xl' : 'bg-white text-slate-900 shadow-sm border border-slate-200' %> flex flex-col rounded-[1.75rem] p-8">
              <span class="text-sm font-bold uppercase tracking-[0.18em] <%= tier.isFeatured ? 'text-sky-100' : 'text-slate-500' %>"><%= tier.eyebrow || 'Package Tier' %></span>
              <h4 class="mt-3 font-serif text-3xl"><%= tier.name || 'Tier' %></h4>
              <div class="mt-5 text-4xl font-bold">
                <%= tier.price || pkg.price || 'On Request' %>
                <% if (tier.priceSuffix) { %>
                  <span class="text-sm font-normal <%= tier.isFeatured ? 'text-sky-100' : 'text-slate-500' %>"><%= tier.priceSuffix %></span>
                <% } %>
              </div>
              <ul class="mt-8 flex-1 space-y-4">
                <% (Array.isArray(tier.features) ? tier.features : []).forEach((feature) => { %>
                  <li class="flex items-start gap-3 text-sm leading-6 <%= tier.isFeatured ? 'text-white/90' : 'text-slate-600' %>">
                    <span class="material-symbols-outlined <%= tier.isFeatured ? 'text-secondary' : 'text-green-600' %>">check_circle</span>
                    <span><%= feature %></span>
                  </li>
                <% }) %>
              </ul>
              <button class="<%= tier.isFeatured ? 'bg-secondary text-white' : 'border-2 border-primary text-primary' %> mt-10 w-full rounded-xl px-5 py-3 text-sm font-bold transition hover:brightness-105"><%= tier.buttonLabel || 'Inquire Now' %></button>
            </article>
          <% }) %>
        </div>
      </section>

      <section class="mx-auto max-w-7xl border-t border-slate-200 px-4 py-24 sm:px-6 lg:px-8">
        <div class="grid gap-16 md:grid-cols-2">
          <div>
            <h4 class="flex items-center gap-2 font-serif text-2xl text-emerald-800">
              <span class="material-symbols-outlined">add_circle</span>
              <span>What's Included</span>
            </h4>
            <ul class="mt-8 space-y-4">
              <% inclusions.forEach((item) => { %>
                <li class="flex items-start gap-3">
                  <span class="material-symbols-outlined mt-1 text-primary text-[18px]">done</span>
                  <span class="text-slate-600"><%= item %></span>
                </li>
              <% }) %>
            </ul>
          </div>
          <div>
            <h4 class="flex items-center gap-2 font-serif text-2xl text-red-700">
              <span class="material-symbols-outlined">remove_circle</span>
              <span>What's Excluded</span>
            </h4>
            <ul class="mt-8 space-y-4">
              <% exclusions.forEach((item) => { %>
                <li class="flex items-start gap-3">
                  <span class="material-symbols-outlined mt-1 text-red-600 text-[18px]">close</span>
                  <span class="text-slate-600"><%= item %></span>
                </li>
              <% }) %>
            </ul>
          </div>
        </div>
      </section>

      <section class="bg-surface-container py-24">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
          <div class="mb-16 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
            <div>
              <h3 class="font-serif text-3xl text-primary">Traveler Journals</h3>
              <p class="mt-2 text-slate-600">Stories from those who explored before you.</p>
            </div>
            <div class="flex items-center gap-1 text-secondary">
              <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1">star</span>
              <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1">star</span>
              <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1">star</span>
              <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1">star</span>
              <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1">star</span>
              <span class="ml-2 font-bold text-primary">4.9/5 Average</span>
            </div>
          </div>
          <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
            <% reviews.forEach((review) => { %>
              <article class="rounded-xl bg-white p-8 shadow-sm">
                <div class="mb-6 flex items-center gap-4">
                  <img src="<%= review.image || heroImage %>" alt="<%= review.name || pkg.name %>" class="h-12 w-12 rounded-full object-cover" />
                  <div>
                    <h5 class="font-bold text-slate-900"><%= review.name || 'Guest Traveler' %></h5>
                    <p class="text-xs uppercase tracking-[0.18em] text-slate-500"><%= review.meta || 'Verified guest' %></p>
                  </div>
                </div>
                <p class="italic leading-8 text-slate-600">"<%= review.quote || 'A memorable and well-curated route from beginning to end.' %>"</p>
              </article>
            <% }) %>
          </div>
        </div>
      </section>
    </main>

    <div class="fixed bottom-0 left-0 z-40 w-full border-t border-slate-200 bg-white/95 backdrop-blur-xl md:bottom-8 md:left-auto md:right-8 md:w-auto md:border-none md:bg-transparent">
      <div class="mx-auto max-w-7xl px-4 py-4 sm:px-6 md:p-0">
        <div class="flex items-center justify-between gap-4 md:w-80 md:flex-col md:items-stretch md:rounded-[1.5rem] md:border md:border-slate-200 md:bg-white md:p-6 md:shadow-2xl">
          <div class="flex flex-col">
            <span class="text-xs font-bold uppercase tracking-[0.18em] text-slate-500">Starting From</span>
            <div class="flex items-baseline gap-1">
              <span class="text-2xl font-bold text-primary"><%= pkg.price || 'On Request' %></span>
              <span class="text-sm text-slate-500"><%= floatingPriceSuffix %></span>
            </div>
          </div>
          <div class="flex gap-4 md:flex-col">
            <button class="flex items-center justify-center gap-2 rounded-xl bg-secondary px-6 py-3 text-sm font-bold text-white transition hover:brightness-105">
              <span class="material-symbols-outlined">bolt</span>
              <span><%= floatingButton %></span>
            </button>
            <button class="hidden items-center justify-center gap-2 rounded-xl border border-slate-300 px-6 py-3 text-sm font-bold text-slate-900 transition hover:bg-slate-50 md:flex">
              <span class="material-symbols-outlined">mail</span>
              <span><%= floatingSecondaryButton %></span>
            </button>
          </div>
        </div>
      </div>
    </div>

    <%- include('partials/footer') %>
  </body>
</html>
