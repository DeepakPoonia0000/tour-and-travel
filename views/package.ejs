<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('partials/head') %>
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-900">
    <%- include('partials/header') %>
    <main class="space-y-12">
      <section class="relative overflow-hidden">
        <div class="absolute inset-0 bg-slate-950/45"></div>
        <div class="h-[420px] bg-cover bg-center" style="background-image:url('<%= pkg.heroImage || '/images/placeholder.jpg' %>')"></div>
        <div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-20">
          <div class="max-w-3xl text-white">
            <p class="text-sm uppercase tracking-[0.28em] text-sky-300 font-semibold">Tour Package</p>
            <h1 class="mt-4 text-5xl font-semibold tracking-tight"><%= pkg.name %></h1>
            <p class="mt-6 text-lg leading-8 text-slate-200"><%= pkg.summary || pkg.description?.slice(0, 180) || 'A fully managed travel package itinerary.' %></p>
            <div class="mt-8 flex flex-wrap gap-4 text-sm text-slate-200">
              <% if (pkg.duration) { %>
                <span class="rounded-full bg-white/10 px-4 py-2"><strong>Duration:</strong> <%= pkg.duration %></span>
              <% } %>
              <% if (pkg.price) { %>
                <span class="rounded-full bg-white/10 px-4 py-2"><strong>Price:</strong> <%= pkg.price %></span>
              <% } %>
            </div>
          </div>
        </div>
      </section>
      <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid gap-8 lg:grid-cols-[1.4fr_0.6fr]">
          <div class="space-y-8 rounded-[2rem] bg-white border border-slate-200 p-10 shadow-sm">
            <div>
              <h2 class="text-3xl font-semibold text-slate-900">Package overview</h2>
              <p class="mt-4 text-slate-600"><%= pkg.description || 'This itinerary is managed through the admin panel with priority-based display across related destination pages.' %></p>
            </div>
            <div class="grid gap-6 lg:grid-cols-2">
              <% if (itineraryCountries.length) { %>
                <div class="rounded-[1.75rem] bg-slate-50 p-6">
                  <h3 class="text-lg font-semibold text-slate-900">Countries</h3>
                  <ul class="mt-4 space-y-2 text-slate-600">
                    <% itineraryCountries.forEach(item => { %>
                      <li><a href="/countries/<%= item.slug %>" class="hover:text-sky-600"><%= item.name %></a></li>
                    <% }) %>
                  </ul>
                </div>
              <% } %>
              <% if (itineraryStates.length) { %>
                <div class="rounded-[1.75rem] bg-slate-50 p-6">
                  <h3 class="text-lg font-semibold text-slate-900">States</h3>
                  <ul class="mt-4 space-y-2 text-slate-600">
                    <% itineraryStates.forEach(item => { %>
                      <li><a href="/states/<%= item.slug %>" class="hover:text-sky-600"><%= item.name %></a></li>
                    <% }) %>
                  </ul>
                </div>
              <% } %>
            </div>
            <div class="grid gap-6 lg:grid-cols-2">
              <% if (itineraryCities.length) { %>
                <div class="rounded-[1.75rem] bg-slate-50 p-6">
                  <h3 class="text-lg font-semibold text-slate-900">Cities</h3>
                  <ul class="mt-4 space-y-2 text-slate-600">
                    <% itineraryCities.forEach(item => { %>
                      <li><a href="/cities/<%= item.slug %>" class="hover:text-sky-600"><%= item.name %></a></li>
                    <% }) %>
                  </ul>
                </div>
              <% } %>
              <% if (itineraryActivities.length) { %>
                <div class="rounded-[1.75rem] bg-slate-50 p-6">
                  <h3 class="text-lg font-semibold text-slate-900">Activities</h3>
                  <ul class="mt-4 space-y-2 text-slate-600">
                    <% itineraryActivities.forEach(item => { %>
                      <li><a href="/activities/<%= item.slug %>" class="hover:text-sky-600"><%= item.name %></a></li>
                    <% }) %>
                  </ul>
                </div>
              <% } %>
            </div>
            <% if (itineraryAttractions.length) { %>
              <div class="rounded-[2rem] bg-slate-50 p-6">
                <h3 class="text-lg font-semibold text-slate-900">Attractions</h3>
                <ul class="mt-4 space-y-2 text-slate-600">
                  <% itineraryAttractions.forEach(item => { %>
                    <li><a href="/attractions/<%= item.slug %>" class="hover:text-sky-600"><%= item.name %></a></li>
                  <% }) %>
                </ul>
              </div>
            <% } %>
          </div>
          <aside class="space-y-6 rounded-[2rem] bg-white border border-slate-200 p-8 shadow-sm">
            <div class="rounded-[1.75rem] bg-slate-50 p-6">
              <h3 class="text-lg font-semibold text-slate-900">Package details</h3>
              <dl class="mt-6 space-y-4 text-sm text-slate-600">
                <% if (pkg.duration) { %>
                  <div><dt class="font-semibold text-slate-900">Duration</dt><dd class="mt-1"><%= pkg.duration %></dd></div>
                <% } %>
                <% if (pkg.price) { %>
                  <div><dt class="font-semibold text-slate-900">Price</dt><dd class="mt-1"><%= pkg.price %></dd></div>
                <% } %>
                <div><dt class="font-semibold text-slate-900">Priority</dt><dd class="mt-1"><%= pkg.priority %></dd></div>
              </dl>
            </div>
            <a href="/packages" class="inline-flex w-full items-center justify-center rounded-2xl bg-slate-950 px-5 py-3 text-sm font-semibold text-white transition hover:bg-slate-800">Browse all packages</a>
          </aside>
        </div>
      </section>
    </main>
    <%- include('partials/footer') %>
  </body>
</html>
