<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('partials/head') %>
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-900">
    <%- include('partials/header') %>
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <section class="rounded-[2rem] bg-white border border-slate-200 shadow-sm p-10 mb-10">
        <p class="text-sm uppercase tracking-[0.28em] font-semibold text-sky-600">Attractions</p>
        <h1 class="mt-4 text-4xl font-semibold tracking-tight text-slate-900">Explore all attractions</h1>
        <p class="mt-4 max-w-3xl text-slate-600">Dynamic attraction pages show priority-ordered highlights across countries, states, and cities.</p>
      </section>
      <section class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <% attractions.forEach(item => { %>
          <article class="group overflow-hidden rounded-[1.75rem] border border-slate-200 bg-white shadow-sm transition duration-200 hover:-translate-y-1 hover:shadow-lg">
            <a href="/attractions/<%= item.slug %>" class="block">
              <div class="h-56 bg-cover bg-center" style="background-image:url('<%= item.heroImage || '/images/placeholder.jpg' %>')"></div>
            </a>
            <div class="p-6">
              <h3 class="text-xl font-semibold text-slate-900">
                <a href="/attractions/<%= item.slug %>" class="hover:text-sky-600"><%= item.name %></a>
              </h3>
              <p class="mt-3 text-sm leading-6 text-slate-600"><%= item.summary || item.description?.slice(0, 120) || 'A destination attraction with local insight.' %></p>
              <p class="mt-4 text-xs uppercase tracking-[0.24em] text-slate-500"><%= item.category || 'Attraction' %></p>
            </div>
          </article>
        <% }) %>
      </section>
    </main>
    <%- include('partials/footer') %>
  </body>
</html>
