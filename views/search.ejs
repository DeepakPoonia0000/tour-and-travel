<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('partials/head') %>
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <header class="mb-8 rounded-[2rem] bg-white border border-slate-200 p-8 shadow-sm">
        <h1 class="text-4xl font-semibold text-slate-900">Search results</h1>
        <p class="mt-3 text-slate-600">Looking for <span class="font-semibold text-slate-900"><%= query ? query : 'something' %></span>.</p>
      </header>

      <form action="/search" method="GET" class="mb-8 flex flex-col gap-3 sm:flex-row sm:items-center">
        <label class="sr-only" for="q">Search query</label>
        <input id="q" name="q" type="search" value="<%= query %>" placeholder="Search countries, cities, attractions, activities, packages" class="w-full rounded-full border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100" />
        <button type="submit" class="inline-flex shrink-0 rounded-full bg-sky-600 px-6 py-3 text-sm font-semibold text-white transition hover:bg-sky-700">Search</button>
      </form>

      <% if (!query) { %>
        <div class="rounded-[2rem] border border-dashed border-slate-300 bg-white p-12 text-center text-slate-600">
          Enter a keyword to search destinations, activities, and packages.
        </div>
      <% } else { %>
        <div class="space-y-10">
          <% const categories = [
            { title: 'Countries', items: countries, href: '/countries' },
            { title: 'States', items: states, href: '/states' },
            { title: 'Cities', items: cities, href: '/cities' },
            { title: 'Attractions', items: attractions, href: '/attractions' },
            { title: 'Activities', items: activities, href: '/activities' },
            { title: 'Packages', items: packages, href: '/packages' }
          ]; %>

          <% const detailRoutes = {
            Countries: '/countries',
            States: '/states',
            Cities: '/cities',
            Attractions: '/attractions',
            Activities: '/activities',
            Packages: '/packages'
          }; %>
          <% categories.forEach((category) => { %>
            <section>
              <div class="mb-4 flex items-center justify-between gap-4">
                <h2 class="text-2xl font-semibold text-slate-900"><%= category.title %></h2>
                <a class="text-sm font-medium text-sky-600 transition hover:text-sky-800" href="<%= category.href %>">Browse all</a>
              </div>

              <% if (!category.items.length) { %>
                <div class="rounded-[1.75rem] border border-slate-200 bg-slate-50 p-6 text-slate-600">No <%= category.title.toLowerCase() %> matched your search.</div>
              <% } else { %>
                <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
                  <% category.items.forEach((item) => { %>
                    <% const detailLink = item.slug ? `${detailRoutes[category.title]}/${item.slug}` : category.href; %>
                    <article class="overflow-hidden rounded-[1.75rem] border border-slate-200 bg-white shadow-sm">
                      <div class="h-48 bg-slate-200">
                        <% if (item.heroImage) { %>
                          <img src="<%= item.heroImage %>" alt="<%= item.name %>" class="h-full w-full object-cover" />
                        <% } else { %>
                          <div class="flex h-full items-center justify-center text-slate-400">No image</div>
                        <% } %>
                      </div>
                      <div class="p-6">
                        <h3 class="text-xl font-semibold text-slate-900"><%= item.name %></h3>
                        <% if (item.summary) { %>
                          <p class="mt-3 text-sm leading-6 text-slate-600"><%= item.summary %></p>
                        <% } %>
                        <% if (category.title === 'Packages') { %>
                          <div class="mt-4 flex flex-wrap gap-2 text-sm text-slate-700">
                            <% if (item.duration) { %><span class="rounded-full bg-slate-100 px-3 py-1"><%= item.duration %></span><% } %>
                            <% if (item.price) { %><span class="rounded-full bg-slate-100 px-3 py-1">$<%= item.price %></span><% } %>
                            <span class="rounded-full bg-slate-100 px-3 py-1"><%= item.itineraryCountries?.length || 0 %> countries</span>
                            <span class="rounded-full bg-slate-100 px-3 py-1"><%= item.itineraryStates?.length || 0 %> states</span>
                            <span class="rounded-full bg-slate-100 px-3 py-1"><%= item.itineraryCities?.length || 0 %> cities</span>
                          </div>
                        <% } %>
                        <div class="mt-6">
                          <a class="inline-flex rounded-full bg-sky-600 px-5 py-3 text-sm font-semibold text-white transition hover:bg-sky-700" href="<%= detailLink %>">View</a>
                        </div>
                      </div>
                    </article>
                  <% }) %>
                </div>
              <% } %>
            </section>
          <% }); %>
        </div>
      <% } %>
    </div>
  </body>
</html>
