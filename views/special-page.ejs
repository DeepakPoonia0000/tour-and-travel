<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('partials/head') %>
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-900">
    <%- include('partials/header') %>
    <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <section class="rounded-[2rem] bg-white border border-slate-200 shadow-sm p-10 mb-10">
        <p class="text-sm uppercase tracking-[0.28em] font-semibold text-sky-600"><%= sectionTitle %></p>
        <h1 class="mt-4 text-4xl font-semibold tracking-tight text-slate-900"><%= sectionTitle %> in <%= entity.name %></h1>
        <p class="mt-4 max-w-3xl text-slate-600">Dynamic content updated by the admin for every location in the travel portal.</p>
      </section>
      <section class="rounded-[2rem] bg-white border border-slate-200 shadow-sm p-10">
        <% if (bodyContent) { %>
          <div class="prose max-w-none text-slate-700"><%= bodyContent %></div>
        <% } else { %>
          <p class="text-slate-600">Content is not yet available for this section. Please add it from the admin interface.</p>
        <% } %>
      </section>
    </main>
    <%- include('partials/footer') %>
  </body>
</html>
