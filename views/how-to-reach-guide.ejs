<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('partials/head') %>
  </head>
  <body class="min-h-screen bg-surface text-slate-900">
    <%- include('partials/header') %>
    <%
      const heroImage = guide.heroImage || entity.heroImage || '/images/placeholder.jpg';
      const heroEyebrow = guide.heroEyebrow || 'Destination Guide';
      const heroTitle = guide.heroTitle || `How to Reach ${entity.name}`;
      const heroDescription = guide.heroDescription || entity.howToReach || entity.summary || `Plan your arrival into ${entity.name}.`;
      const heroCardTitle = guide.heroCardTitle || 'Arrival Guide';
      const heroCardText = guide.heroCardText || 'Use this transport guide to choose the smoothest route into the destination.';
      const sections = Array.isArray(guide.sections) ? guide.sections.filter((section) => section && (section.title || section.description || section.image || (section.items && section.items.length))) : [];
      const mapTitle = guide.mapTitle || 'Connectivity Visualized';
      const mapDescription = guide.mapDescription || 'Use this guide to navigate the final approach into the destination.';
      const mapImage = guide.mapImage || heroImage;
      const finalMile = guide.finalMile || {};
      const tip = guide.connectivityTip || {};
      const itemTypeMap = { city: 'cities', attraction: 'attractions', activity: 'activities' };
      const itemLabelMap = { city: 'City', attraction: 'Attraction', activity: 'Activity' };
    %>
    <main class="pb-24 pt-24">
      <header class="relative flex min-h-[760px] items-end overflow-hidden pb-24">
        <div class="absolute inset-0">
          <img alt="<%= guide.heroImageAlt || heroTitle %>" class="h-full w-full object-cover" src="<%= heroImage %>"/>
          <div class="absolute inset-0 bg-gradient-to-t from-primary/70 via-primary/20 to-transparent"></div>
        </div>
        <div class="relative z-10 mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
          <div class="max-w-4xl">
            <span class="block text-sm tracking-[0.2em] text-white/90"><%= heroEyebrow %></span>
            <h1 class="mt-4 font-serif text-6xl font-black leading-tight text-white md:text-8xl"><%= heroTitle %></h1>
            <div class="mt-8 max-w-xl rounded-lg bg-white p-8 shadow-2xl">
              <h2 class="font-serif text-2xl text-primary"><%= heroCardTitle %></h2>
              <p class="mt-4 text-lg leading-relaxed text-slate-600"><%= heroCardText %></p>
            </div>
          </div>
        </div>
      </header>

      <main class="mx-auto mt-20 max-w-7xl space-y-24 px-4 sm:px-6 lg:px-8">
        <% if (sections.length) { %>
          <% sections.forEach((section, index) => { %>
            <section class="grid grid-cols-1 gap-12 lg:grid-cols-12 lg:items-start">
              <div class="space-y-8 <%= index === 1 ? 'lg:col-span-6 lg:order-2' : 'lg:col-span-5' %>">
                <div class="space-y-4">
                  <% if (section.eyebrow) { %>
                    <span class="text-xs font-bold uppercase tracking-widest text-secondary"><%= section.eyebrow %></span>
                  <% } %>
                  <h2 class="font-serif text-4xl leading-tight text-primary md:text-5xl"><%= section.title || `Section ${index + 1}` %></h2>
                </div>
                <% if (section.description) { %>
                  <p class="text-lg leading-relaxed text-slate-600"><%= section.description %></p>
                <% } %>
                <% if (section.items && section.items.length) { %>
                  <div class="space-y-4">
                    <% section.items.forEach((item) => { %>
                      <div class="rounded-xl bg-slate-50 p-6">
                        <h3 class="font-serif text-xl text-primary"><%= item.name %></h3>
                        <% if (item.description) { %>
                          <p class="mt-2 text-sm text-slate-600"><%= item.description %></p>
                        <% } %>
                        <% if (item.detail) { %>
                          <div class="mt-4 font-semibold text-secondary"><%= item.detail %></div>
                        <% } %>
                      </div>
                    <% }) %>
                  </div>
                <% } %>
                <% if (section.quote) { %>
                  <div class="rounded-lg bg-primary p-6 text-white">
                    <p class="font-serif italic"><%= section.quote %></p>
                  </div>
                <% } %>
              </div>
              <div class="<%= index === 1 ? 'lg:col-span-6 lg:order-1' : 'lg:col-span-7' %>">
                <div class="overflow-hidden rounded-xl">
                  <img alt="<%= section.imageAlt || section.title || 'Travel image' %>" class="h-full w-full object-cover" src="<%= section.image || heroImage %>"/>
                </div>
              </div>
            </section>
          <% }) %>
        <% } else { %>
          <section class="rounded-[2rem] bg-white p-10 shadow-sm ring-1 ring-slate-200">
            <h2 class="font-serif text-3xl text-slate-900">How-to-reach guide is not filled out yet</h2>
            <p class="mt-4 max-w-2xl leading-8 text-slate-600">Add the structured how-to-reach fields in admin to turn this into the stitched access guide.</p>
          </section>
        <% } %>

        <section>
          <div class="mx-auto mb-12 max-w-2xl text-center">
            <h2 class="font-serif text-4xl text-primary"><%= mapTitle %></h2>
            <p class="mt-4 text-slate-600"><%= mapDescription %></p>
          </div>
          <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
            <div class="md:col-span-2 overflow-hidden rounded-2xl bg-slate-100">
              <img alt="<%= guide.mapImageAlt || mapTitle %>" class="h-full w-full object-cover" src="<%= mapImage %>"/>
            </div>
            <div class="space-y-8">
              <div class="rounded-2xl bg-white p-8 shadow-sm ring-1 ring-slate-200">
                <span class="text-[10px] font-extrabold uppercase tracking-tight text-secondary">Connectivity Tip</span>
                <h3 class="mt-2 font-serif text-xl text-primary"><%= tip.title || 'Local Access Tip' %></h3>
                <p class="mt-4 text-sm leading-relaxed text-slate-600"><%= tip.description || 'Add a local transport tip in admin.' %></p>
                <% if (tip.buttonLabel) { %>
                  <button class="mt-6 w-full rounded-lg border border-slate-200 py-3 text-xs font-bold uppercase tracking-widest text-primary"><%= tip.buttonLabel %></button>
                <% } %>
              </div>
              <div class="rounded-2xl bg-primary p-8 text-white">
                <h3 class="font-serif text-xl"><%= finalMile.title || 'The Final Mile' %></h3>
                <p class="mt-4 text-sm leading-relaxed text-blue-100"><%= finalMile.description || 'Add final-mile travel advice in admin.' %></p>
                <div class="mt-6 flex flex-wrap gap-2 text-[10px] font-bold uppercase tracking-tight">
                  <% if (guide.mapBadgeOne) { %><span class="rounded bg-white/15 px-2 py-1"><%= guide.mapBadgeOne %></span><% } %>
                  <% if (guide.mapBadgeTwo) { %><span class="rounded bg-white/15 px-2 py-1"><%= guide.mapBadgeTwo %></span><% } %>
                </div>
              </div>
            </div>
          </div>
        </section>

        <% if (linkedEntries && linkedEntries.length) { %>
          <section>
            <h2 class="font-serif text-3xl text-slate-900"><%= linkedEntriesTitle %></h2>
            <div class="mt-6 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
              <% linkedEntries.forEach((item) => { %>
                <% const itemType = itemTypeMap[item.entryType] || 'cities'; %>
                <% const itemLabel = itemLabelMap[item.entryType] || 'Entry'; %>
                <article class="overflow-hidden rounded-[1.75rem] bg-white shadow-sm ring-1 ring-slate-200">
                  <a href="/<%= itemType %>/<%= item.slug %>" class="block">
                    <div class="h-48 bg-cover bg-center" style="background-image:url('<%= item.heroImage || '/images/placeholder.jpg' %>')"></div>
                    <div class="p-6">
                      <p class="text-xs font-bold uppercase tracking-[0.24em] text-slate-500"><%= itemLabel %></p>
                      <h3 class="mt-3 font-serif text-2xl text-slate-900"><%= item.name %></h3>
                    </div>
                  </a>
                </article>
              <% }) %>
            </div>
          </section>
        <% } %>
      </main>
    </main>
    <%- include('partials/footer') %>
  </body>
</html>
