<% if (pagination && pagination.totalPages > 1) { %>
  <% const page = pagination.page; const totalPages = pagination.totalPages; const limit = pagination.limit; const baseUrl = pagination.baseUrl; %>
  <% const startPage = Math.max(1, page - 2); const endPage = Math.min(totalPages, page + 2); %>
  <section class="mt-10">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <p class="text-sm text-slate-600">Showing page <%= page %> of <%= totalPages %></p>
      <nav class="flex flex-wrap items-center gap-2" aria-label="Pagination">
        <% const queryString = pagination.query ? `&${pagination.query}` : ''; %>
        <a class="inline-flex items-center rounded-full border px-4 py-2 text-sm font-medium transition <%= page === 1 ? 'cursor-not-allowed border-slate-200 bg-slate-100 text-slate-400' : 'border-slate-300 bg-white text-slate-700 hover:border-slate-400 hover:bg-slate-50' %>" href="<%= page === 1 ? '#' : `${baseUrl}?page=${page-1}&limit=${limit}${queryString}` %>">Previous</a>
        <% for (let number = startPage; number <= endPage; number += 1) { %>
          <a class="inline-flex items-center rounded-full px-4 py-2 text-sm font-medium transition <%= number === page ? 'border border-sky-600 bg-sky-600 text-white' : 'border border-slate-300 bg-white text-slate-700 hover:border-slate-400 hover:bg-slate-50' %>" href="<%= `${baseUrl}?page=${number}&limit=${limit}${queryString}` %>"><%= number %></a>
        <% } %>
        <a class="inline-flex items-center rounded-full border px-4 py-2 text-sm font-medium transition <%= page === totalPages ? 'cursor-not-allowed border-slate-200 bg-slate-100 text-slate-400' : 'border-slate-300 bg-white text-slate-700 hover:border-slate-400 hover:bg-slate-50' %>" href="<%= page === totalPages ? '#' : `${baseUrl}?page=${page+1}&limit=${limit}${queryString}` %>">Next</a>
      </nav>
    </div>
  </section>
<% } %>
