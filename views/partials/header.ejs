<header class="fixed inset-x-0 top-0 z-50 bg-white/90 backdrop-blur-xl border-b border-slate-200/50">
  <div class="mx-auto flex max-w-screen-2xl items-center justify-between gap-6 px-6 py-4">
    <a class="text-2xl font-serif font-semibold tracking-tight text-slate-950" href="/">The Editorial Explorer</a>
    <nav class="hidden items-center gap-8 lg:flex">
      <a class="text-sm font-medium text-slate-700 transition hover:text-slate-950" href="/countries">Countries</a>
      <a class="text-sm font-medium text-slate-700 transition hover:text-slate-950" href="/states">States</a>
      <a class="text-sm font-medium text-slate-700 transition hover:text-slate-950" href="/cities">Cities</a>
      <a class="text-sm font-medium text-slate-700 transition hover:text-slate-950" href="/activities">Activities</a>
      <a class="text-sm font-medium text-slate-700 transition hover:text-slate-950" href="/attractions">Attractions</a>
      <a class="text-sm font-medium text-slate-700 transition hover:text-slate-950" href="/packages">Packages</a>
    </nav>
    <div class="flex items-center gap-3">
      <form action="/search" method="GET" class="relative">
        <input name="q" type="search" placeholder="Search destinations" value="<%= typeof query !== 'undefined' ? query : '' %>" class="w-56 rounded-full border border-slate-300 bg-white px-4 py-2 text-sm text-slate-700 outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100" />
        <button type="submit" class="absolute right-1 top-1/2 -translate-y-1/2 rounded-full bg-slate-900 px-3 py-2 text-sm font-semibold text-white transition hover:bg-slate-800">Go</button>
      </form>
    </div>
    <div class="flex items-center gap-3">
      <% if (admin) { %>
        <form action="/admin/logout" method="POST" class="inline">
          <button type="submit" class="rounded-full bg-slate-950 px-5 py-2 text-sm font-semibold text-white transition hover:bg-slate-800">Admin</button>
        </form>
      <% } else { %>
        <a class="rounded-full border border-slate-300 bg-white px-5 py-2 text-sm font-semibold text-slate-950 transition hover:bg-slate-50" href="/admin/login">Admin</a>
      <% } %>
    </div>
  </div>
</header>
