<% if (relatedBlogs && relatedBlogs.length) { %>
  <section class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
    <div class="mb-12 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div>
        <span class="text-sm font-bold uppercase tracking-[0.3em] text-secondary">Travel Journal</span>
        <h2 class="mt-3 font-serif text-3xl text-primary sm:text-4xl"><%= relatedBlogsTitle || 'Related Blogs' %></h2>
        <p class="mt-4 max-w-2xl text-base leading-8 text-slate-600">
          <%= relatedBlogsIntro || 'Read editorials and destination stories linked to this page.' %>
        </p>
      </div>
      <a href="/blogs" class="inline-flex w-fit items-center gap-2 rounded-full border border-slate-300 bg-white px-5 py-3 text-sm font-semibold text-slate-900 transition hover:border-primary hover:text-primary">
        Browse all blogs
        <span class="material-symbols-outlined text-lg">north_east</span>
      </a>
    </div>

    <div class="grid gap-8 md:grid-cols-3">
      <% relatedBlogs.forEach((blog) => { %>
        <a href="/blogs/<%= blog.slug %>" class="group overflow-hidden rounded-[2rem] bg-white shadow-sm ring-1 ring-slate-200 transition hover:-translate-y-1 hover:shadow-xl">
          <div class="h-72 overflow-hidden bg-slate-100">
            <img class="h-full w-full object-cover transition duration-700 group-hover:scale-110" src="<%= blog.heroImage || '/images/placeholder.jpg' %>" alt="<%= blog.name %>"/>
          </div>
          <div class="p-8">
            <p class="text-xs font-bold uppercase tracking-[0.22em] text-slate-500"><%= blog.primaryCategory || 'Journal' %></p>
            <h3 class="mt-3 font-serif text-2xl text-slate-900 transition-colors group-hover:text-primary"><%= blog.name %></h3>
            <p class="mt-4 text-sm leading-7 text-slate-600"><%= blog.summary || blog.description || 'Open this destination story.' %></p>
          </div>
        </a>
      <% }) %>
    </div>
  </section>
<% } %>
