<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('partials/head') %>
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-900">
    <%- include('partials/header') %>
    <main class="space-y-12">
      <section class="relative overflow-hidden">
        <div class="absolute inset-0 bg-slate-950/45"></div>
        <div class="h-[420px] bg-cover bg-center" style="background-image:url('<%= country.heroImage || '/images/placeholder.jpg' %>')"></div>
        <div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-20">
          <div class="max-w-3xl text-white">
            <p class="text-sm uppercase tracking-[0.28em] text-sky-300 font-semibold">Country Spotlight</p>
            <h1 class="mt-4 text-5xl font-semibold tracking-tight"><%= country.name %></h1>
            <p class="mt-6 text-lg leading-8 text-slate-200"><%= country.summary || country.description?.slice(0, 160) || 'Explore top destinations and curated travel guides.' %></p>
          </div>
        </div>
      </section>

      <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid gap-8 lg:grid-cols-[1.4fr_0.6fr] items-start">
          <div class="rounded-[1.75rem] bg-white border border-slate-200 p-10 shadow-sm">
            <h2 class="text-3xl font-semibold text-slate-900">About <%= country.name %></h2>
            <p class="mt-4 text-slate-600"><%= country.description || 'This destination is managed by the admin and displays dynamic travel content across all sections.' %></p>
          </div>
          <div class="rounded-[1.75rem] bg-white border border-slate-200 p-8 shadow-sm">
            <div class="space-y-3">
              <a href="/countries/<%= country.slug %>/things-to-do" class="block rounded-2xl border border-slate-200 bg-slate-50 px-4 py-4 text-slate-900 transition hover:bg-slate-100">Things to do</a>
              <a href="/countries/<%= country.slug %>/places-to-visit" class="block rounded-2xl border border-slate-200 bg-slate-50 px-4 py-4 text-slate-900 transition hover:bg-slate-100">Places to visit</a>
              <a href="/countries/<%= country.slug %>/best-time-to-visit" class="block rounded-2xl border border-slate-200 bg-slate-50 px-4 py-4 text-slate-900 transition hover:bg-slate-100">Best time to visit</a>
              <a href="/countries/<%= country.slug %>/how-to-reach" class="block rounded-2xl border border-slate-200 bg-slate-50 px-4 py-4 text-slate-900 transition hover:bg-slate-100">How to reach</a>
              <a href="/countries/<%= country.slug %>/hotels" class="block rounded-2xl border border-slate-200 bg-slate-50 px-4 py-4 text-slate-900 transition hover:bg-slate-100">Hotels</a>
            </div>
          </div>
        </div>
      </section>

      <section class="bg-slate-50 py-12">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between mb-6">
            <div>
              <p class="text-sm uppercase tracking-[0.28em] text-sky-600 font-semibold">Regional travel</p>
              <h2 class="mt-2 text-3xl font-semibold text-slate-900">States & cities</h2>
            </div>
            <div class="flex flex-wrap gap-3">
              <a href="/countries/<%= country.slug %>/cities" class="rounded-full bg-white px-5 py-3 text-sm font-medium text-slate-900 shadow-sm ring-1 ring-slate-200 transition hover:bg-slate-100">View cities</a>
            </div>
          </div>
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 mb-8">
            <% states.slice(0, 6).forEach(state => { %>
              <a href="/states/<%= state.slug %>" class="group rounded-[1.75rem] border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-lg">
                <strong class="text-lg font-semibold text-slate-900"><%= state.name %></strong>
                <p class="mt-3 text-sm leading-6 text-slate-600"><%= state.summary?.slice(0, 80) || 'Discover this region.' %></p>
              </a>
            <% }) %>
          </div>
          <div class="grid gap-6 lg:grid-cols-3">
            <% cities.slice(0, 6).forEach(city => { %>
              <article class="overflow-hidden rounded-[1.75rem] border border-slate-200 bg-white shadow-sm">
                <a href="/cities/<%= city.slug %>" class="block">
                  <div class="h-52 bg-cover bg-center" style="background-image:url('<%= city.heroImage || '/images/placeholder.jpg' %>')"></div>
                </a>
                <div class="p-6">
                  <h3 class="text-xl font-semibold text-slate-900"><a href="/cities/<%= city.slug %>" class="hover:text-sky-600"><%= city.name %></a></h3>
                  <p class="mt-3 text-sm leading-6 text-slate-600"><%= city.summary || city.description?.slice(0, 120) || 'City-level travel details and attractions.' %></p>
                </div>
              </article>
            <% }) %>
          </div>
        </div>
      </section>

      <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between mb-6">
          <div>
            <p class="text-sm uppercase tracking-[0.28em] text-sky-600 font-semibold">Live experiences</p>
            <h2 class="mt-2 text-3xl font-semibold text-slate-900">Attractions and activities</h2>
          </div>
          <div class="flex flex-wrap gap-3">
            <a href="/countries/<%= country.slug %>/attractions" class="rounded-full bg-white px-5 py-3 text-sm font-medium text-slate-900 shadow-sm ring-1 ring-slate-200 transition hover:bg-slate-100">All attractions</a>
            <a href="/countries/<%= country.slug %>/activities" class="rounded-full bg-white px-5 py-3 text-sm font-medium text-slate-900 shadow-sm ring-1 ring-slate-200 transition hover:bg-slate-100">All activities</a>
          </div>
        </div>
        <div class="grid gap-6 lg:grid-cols-2">
          <div class="space-y-4">
            <% attractions.slice(0, 5).forEach(item => { %>
              <a href="/attractions/<%= item.slug %>" class="block rounded-[1.5rem] border border-slate-200 bg-white p-5 text-slate-900 transition hover:bg-slate-50">
                <strong class="text-lg font-semibold"><%= item.name %></strong>
                <span class="mt-2 block text-sm text-slate-600"><%= item.category || 'Attraction' %></span>
              </a>
            <% }) %>
          </div>
          <div class="space-y-4">
            <% activities.slice(0, 5).forEach(item => { %>
              <a href="/activities/<%= item.slug %>" class="block rounded-[1.5rem] border border-slate-200 bg-white p-5 text-slate-900 transition hover:bg-slate-50">
                <strong class="text-lg font-semibold"><%= item.name %></strong>
                <span class="mt-2 block text-sm text-slate-600"><%= item.category || 'Activity' %></span>
              </a>
            <% }) %>
          </div>
        </div>
      </section>
    </main>
    <%- include('partials/footer') %>
  </body>
</html>
