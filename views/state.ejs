<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('partials/head') %>
    <style>
      .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 500, 'GRAD' 0, 'opsz' 24;
      }

      .glass-effect {
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
      }

      .perspective-card {
        transition: transform 0.35s ease, box-shadow 0.35s ease;
      }

      .perspective-card:hover {
        transform: translateY(-8px) scale(1.01);
      }
    </style>
  </head>
  <body class="min-h-screen bg-surface text-slate-900">
    <%- include('partials/header') %>
    <%
      const heroImage = state.heroImage || '/images/placeholder.jpg';
      const stateSummary = state.summary || state.description?.slice(0, 220) || 'Explore the region through editorial city guides, must-visit landmarks, and immersive local experiences.';
      const longDescription = state.description || 'This state page is dynamically generated from admin-managed content and surfaces cities, attractions, activities, and curated travel planning links.';
      const cityHighlights = cities.slice(0, 3);
      const attractionHighlights = attractions.slice(0, 3);
      const activityHighlights = activities.slice(0, 5);
      const featuredPackages = packages.slice(0, 3);
      const travelLinks = [
        { label: 'Things to do', href: `/states/${state.slug}/things-to-do` },
        { label: 'Places to visit', href: `/states/${state.slug}/places-to-visit` },
        { label: 'Best time to visit', href: `/states/${state.slug}/best-time-to-visit` },
        { label: 'How to reach', href: `/states/${state.slug}/how-to-reach` },
        { label: 'Hotels', href: `/states/${state.slug}/hotels` }
      ];
    %>
    <main class="pb-20 pt-24">
      <section class="w-full">
        <div class="relative overflow-hidden shadow-2xl">
          <div class="absolute inset-0 bg-cover bg-center" style="background-image:url('<%= heroImage %>')"></div>
          <div class="absolute inset-0 bg-gradient-to-t from-primary via-primary/50 to-slate-950/20"></div>
          <div class="relative flex min-h-[620px] flex-col justify-end px-8 py-12 sm:px-12 lg:min-h-[760px]">
            <div class="mx-auto w-full max-w-7xl">
              <div class="max-w-3xl">
              <span class="inline-flex rounded-full bg-accent px-4 py-2 text-xs font-bold uppercase tracking-[0.32em] text-slate-950">
                State Landing
              </span>
              <h1 class="mt-6 font-serif text-4xl leading-tight text-white sm:text-6xl lg:text-7xl">
                <%= state.name %>: stories, cities, and standout experiences.
              </h1>
              <p class="mt-6 max-w-2xl text-base leading-8 text-white/88 sm:text-lg">
                <%= stateSummary %>
              </p>
            </div>
            </div>
          </div>

          <div class="relative mx-auto border-t border-white/15 bg-white/10 px-6 py-6 glass-effect sm:px-10 lg:absolute lg:bottom-8 lg:left-1/2 lg:w-full lg:max-w-7xl lg:-translate-x-1/2 lg:rounded-[1.75rem] lg:border lg:border-white/20">
            <div class="grid gap-4 sm:grid-cols-2">
              <div class="rounded-2xl bg-white/90 p-4">
                <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">Country</p>
                <p class="mt-2 text-lg font-semibold text-slate-900"><%= state.country.name %></p>
              </div>
              <div class="rounded-2xl bg-white/90 p-4">
                <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">Cities</p>
                <p class="mt-2 text-lg font-semibold text-slate-900"><%= cities.length %> destinations</p>
              </div>
              <div class="rounded-2xl bg-white/90 p-4">
                <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">Attractions</p>
                <p class="mt-2 text-lg font-semibold text-slate-900"><%= attractions.length %> highlights</p>
              </div>
              <div class="rounded-2xl bg-white/90 p-4">
                <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">Activities</p>
                <p class="mt-2 text-lg font-semibold text-slate-900"><%= activities.length %> experiences</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <nav class="flex flex-wrap items-center gap-2 py-6 text-sm text-slate-500">
          <a class="transition hover:text-primary" href="/">Home</a>
          <span class="material-symbols-outlined text-base text-slate-400">chevron_right</span>
          <a class="transition hover:text-primary" href="/countries/<%= state.country.slug %>"><%= state.country.name %></a>
          <span class="material-symbols-outlined text-base text-slate-400">chevron_right</span>
          <span class="font-semibold text-slate-900"><%= state.name %></span>
        </nav>
      </div>

      <section class="mx-auto mt-16 max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-8 lg:grid-cols-[1.15fr_0.85fr]">
          <div class="rounded-[2rem] bg-white p-8 shadow-sm ring-1 ring-slate-200 sm:p-10">
            <span class="text-sm font-bold uppercase tracking-[0.3em] text-secondary">Editorial Overview</span>
            <h2 class="mt-4 font-serif text-3xl text-primary sm:text-4xl">About <%= state.name %></h2>
            <p class="mt-6 text-base leading-8 text-slate-600">
              <%= longDescription %>
            </p>
            <% if (featuredPackages.length) { %>
              <div class="mt-8 grid gap-4 md:grid-cols-3">
                <% featuredPackages.forEach((pkg) => { %>
                  <a href="/packages/<%= pkg.slug %>" class="rounded-2xl bg-surface2 p-5 transition hover:-translate-y-1 hover:shadow-md">
                    <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">Package</p>
                    <h3 class="mt-2 text-lg font-semibold text-slate-900"><%= pkg.name %></h3>
                    <p class="mt-3 text-sm leading-6 text-slate-600"><%= pkg.summary || 'Curated itinerary covering this state and nearby highlights.' %></p>
                  </a>
                <% }) %>
              </div>
            <% } %>
          </div>

          <div class="rounded-[2rem] bg-primary p-8 text-white shadow-xl sm:p-10">
            <span class="text-sm font-bold uppercase tracking-[0.3em] text-white/70">Plan Your Visit</span>
            <div class="mt-6 space-y-3">
              <% travelLinks.forEach((item) => { %>
                <a href="<%= item.href %>" class="flex items-center justify-between rounded-2xl bg-white/10 px-5 py-4 transition hover:bg-white/15">
                  <span class="font-medium"><%= item.label %></span>
                  <span class="material-symbols-outlined text-lg">arrow_forward</span>
                </a>
              <% }) %>
            </div>
            <div class="mt-8 rounded-[1.5rem] bg-white/10 p-5 text-sm leading-7 text-white/80">
              This section stays dynamic, so the travel guidance pages continue to reflect the latest admin-managed content for <%= state.name %>.
            </div>
          </div>
        </div>
      </section>

      <section class="mx-auto mt-20 max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mb-10 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
          <div>
            <span class="text-sm font-bold uppercase tracking-[0.3em] text-secondary">City Highlights</span>
            <h2 class="mt-3 font-serif text-3xl text-primary sm:text-4xl">A state told through its cities</h2>
          </div>
          <a href="/states/<%= state.slug %>/cities" class="inline-flex w-fit items-center gap-2 rounded-full border border-slate-300 bg-white px-5 py-3 text-sm font-semibold text-slate-900 transition hover:border-primary hover:text-primary">
            Explore all cities
            <span class="material-symbols-outlined text-lg">north_east</span>
          </a>
        </div>

        <% if (cityHighlights.length) { %>
          <div class="grid gap-8 lg:grid-cols-12 lg:grid-rows-2 lg:[grid-auto-rows:minmax(0,1fr)]">
            <% cityHighlights.forEach((city, index) => { %>
              <article class="<%= index === 0 ? 'lg:col-span-7 lg:row-span-2 min-h-[420px] lg:min-h-[640px]' : 'lg:col-span-5 min-h-[300px]' %> group perspective-card relative overflow-hidden rounded-[2rem] shadow-xl">
                <a href="/cities/<%= city.slug %>" class="absolute inset-0 block">
                  <div class="absolute inset-0 bg-cover bg-center transition duration-700 group-hover:scale-105" style="background-image:url('<%= city.heroImage || '/images/placeholder.jpg' %>')"></div>
                  <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/20 to-transparent"></div>
                  <div class="absolute bottom-0 left-0 p-6 sm:p-8">
                    <p class="text-xs font-semibold uppercase tracking-[0.24em] text-white/70">City</p>
                    <h3 class="mt-3 font-serif text-3xl text-white <%= index === 0 ? 'sm:text-5xl' : 'sm:text-3xl' %>"><%= city.name %></h3>
                    <p class="mt-3 max-w-lg text-sm leading-7 text-white/80 sm:text-base">
                      <%= city.summary || city.description?.slice(0, 140) || 'Explore a signature urban stop within this state.' %>
                    </p>
                  </div>
                </a>
              </article>
            <% }) %>
          </div>
        <% } else { %>
          <div class="rounded-[2rem] bg-white p-10 text-slate-600 shadow-sm ring-1 ring-slate-200">
            City highlights will appear here as soon as destinations are added for this state.
          </div>
        <% } %>
      </section>

      <section class="mt-20 bg-surface2 py-20">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
          <div class="text-center">
            <span class="text-sm font-bold uppercase tracking-[0.3em] text-secondary">Must Visit</span>
            <h2 class="mt-4 font-serif text-3xl text-primary sm:text-4xl">Echoes of grandeur across <%= state.name %></h2>
          </div>

          <% if (attractionHighlights.length) { %>
            <div class="mt-14 grid gap-8 md:grid-cols-3">
              <% attractionHighlights.forEach((item, index) => { %>
                <article class="group overflow-hidden rounded-[2rem] bg-white shadow-sm transition duration-300 hover:-translate-y-2 hover:shadow-xl <%= index === 1 ? 'md:translate-y-8' : '' %>">
                  <a href="/attractions/<%= item.slug %>" class="block">
                    <div class="h-72 overflow-hidden">
                      <div class="h-full w-full bg-cover bg-center transition duration-700 group-hover:scale-110" style="background-image:url('<%= item.heroImage || '/images/placeholder.jpg' %>')"></div>
                    </div>
                    <div class="p-8">
                      <div class="flex items-start justify-between gap-4">
                        <h3 class="font-serif text-2xl text-primary"><%= item.name %></h3>
                        <span class="rounded-full bg-primary/10 px-3 py-1 text-xs font-bold uppercase tracking-[0.18em] text-primary">
                          <%= item.category || 'Attraction' %>
                        </span>
                      </div>
                      <p class="mt-5 text-sm leading-7 text-slate-600">
                        <%= item.summary || item.description?.slice(0, 140) || 'A signature landmark worth building into your route.' %>
                      </p>
                      <div class="mt-6 border-t border-slate-200 pt-5 text-sm text-slate-500">
                        Discover this highlight in <%= state.name %>
                      </div>
                    </div>
                  </a>
                </article>
              <% }) %>
            </div>
          <% } else { %>
            <div class="mt-14 rounded-[2rem] bg-white p-10 text-slate-600 shadow-sm ring-1 ring-slate-200">
              Attractions for this state will appear here once they are added.
            </div>
          <% } %>
        </div>
      </section>

      <section class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
        <div class="grid gap-12 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
          <div class="relative min-h-[360px] overflow-hidden rounded-[2rem] shadow-2xl lg:min-h-[560px]">
            <div class="absolute inset-0 bg-cover bg-center" style="background-image:url('<%= (activities[0] && activities[0].heroImage) || heroImage %>')"></div>
            <div class="absolute inset-0 bg-primary/30 mix-blend-multiply"></div>
          </div>

          <div>
            <span class="text-sm font-bold uppercase tracking-[0.3em] text-secondary">Curated Experiences</span>
            <h2 class="mt-4 font-serif text-3xl text-primary sm:text-4xl">Activities with local character</h2>
            <p class="mt-6 max-w-2xl text-base leading-8 text-slate-600">
              The activity stream remains fully dynamic, so each state can feature everything from quiet cultural trails to high-energy day plans without losing the stitched editorial feel.
            </p>

            <% if (activityHighlights.length) { %>
              <div class="mt-8 flex flex-wrap gap-3">
                <% activityHighlights.forEach((item, index) => { %>
                  <a href="/activities/<%= item.slug %>" class="rounded-full px-5 py-3 text-sm font-semibold transition <%= index === 0 ? 'bg-accent text-slate-950 hover:brightness-95' : 'bg-slate-100 text-slate-800 hover:bg-primary hover:text-white' %>">
                    <%= item.name %>
                  </a>
                <% }) %>
              </div>
            <% } %>

            <div class="mt-10 space-y-4">
              <a href="/states/<%= state.slug %>/things-to-do" class="flex items-start gap-4 rounded-[1.5rem] bg-white p-5 shadow-sm ring-1 ring-slate-200 transition hover:shadow-md">
                <span class="material-symbols-outlined mt-1 text-3xl text-secondary">eco</span>
                <span>
                  <strong class="block text-base text-primary">Things to do guide</strong>
                  <span class="mt-1 block text-sm leading-6 text-slate-600">Browse the editorial planning page that pulls together the state’s recommended experiences.</span>
                </span>
              </a>
              <a href="/states/<%= state.slug %>/places-to-visit" class="flex items-start gap-4 rounded-[1.5rem] bg-white p-5 shadow-sm ring-1 ring-slate-200 transition hover:shadow-md">
                <span class="material-symbols-outlined mt-1 text-3xl text-secondary">verified_user</span>
                <span>
                  <strong class="block text-base text-primary">Places to visit guide</strong>
                  <span class="mt-1 block text-sm leading-6 text-slate-600">Jump straight into the admin-managed destination content for landmarks, regions, and planning notes.</span>
                </span>
              </a>
            </div>
          </div>
        </div>
      </section>
    </main>
    <%- include('partials/footer') %>
  </body>
</html>
