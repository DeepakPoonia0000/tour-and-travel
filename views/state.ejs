<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('partials/head') %>
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-900">
    <%- include('partials/header') %>
    <main class="space-y-12">
      <section class="relative overflow-hidden">
        <div class="absolute inset-0 bg-slate-950/45"></div>
        <div class="h-[420px] bg-cover bg-center" style="background-image:url('<%= state.heroImage || '/images/placeholder.jpg' %>')"></div>
        <div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-20">
          <div class="max-w-3xl text-white">
            <p class="text-sm uppercase tracking-[0.28em] text-sky-300 font-semibold">State Spotlight</p>
            <h1 class="mt-4 text-4xl font-semibold tracking-tight"><%= state.name %>, <%= state.country.name %></h1>
            <p class="mt-6 text-lg leading-8 text-slate-200"><%= state.summary || state.description?.slice(0, 160) || 'Explore local travel guides for this region.' %></p>
          </div>
        </div>
      </section>

      <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid gap-8 lg:grid-cols-[1.4fr_0.6fr] items-start">
          <div class="rounded-[1.75rem] bg-white border border-slate-200 p-10 shadow-sm">
            <h2 class="text-3xl font-semibold text-slate-900">About <%= state.name %></h2>
            <p class="mt-4 text-slate-600"><%= state.description || 'This state contains curated travel recommendations from the admin.' %></p>
          </div>
          <div class="rounded-[1.75rem] bg-white border border-slate-200 p-8 shadow-sm">
            <div class="space-y-3">
              <a href="/states/<%= state.slug %>/things-to-do" class="block rounded-2xl border border-slate-200 bg-slate-50 px-4 py-4 text-slate-900 transition hover:bg-slate-100">Things to do</a>
              <a href="/states/<%= state.slug %>/places-to-visit" class="block rounded-2xl border border-slate-200 bg-slate-50 px-4 py-4 text-slate-900 transition hover:bg-slate-100">Places to visit</a>
              <a href="/states/<%= state.slug %>/best-time-to-visit" class="block rounded-2xl border border-slate-200 bg-slate-50 px-4 py-4 text-slate-900 transition hover:bg-slate-100">Best time to visit</a>
              <a href="/states/<%= state.slug %>/how-to-reach" class="block rounded-2xl border border-slate-200 bg-slate-50 px-4 py-4 text-slate-900 transition hover:bg-slate-100">How to reach</a>
              <a href="/states/<%= state.slug %>/hotels" class="block rounded-2xl border border-slate-200 bg-slate-50 px-4 py-4 text-slate-900 transition hover:bg-slate-100">Hotels</a>
            </div>
          </div>
        </div>
      </section>

      <section class="bg-slate-50 py-12">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between mb-6">
            <div>
              <p class="text-sm uppercase tracking-[0.28em] text-sky-600 font-semibold">Cities</p>
              <h2 class="mt-2 text-3xl font-semibold text-slate-900">Top cities in this state</h2>
            </div>
            <a href="/states/<%= state.slug %>/cities" class="inline-flex items-center justify-center rounded-full bg-white px-5 py-3 text-sm font-medium text-slate-900 shadow-sm ring-1 ring-slate-200 transition hover:bg-slate-100">View all cities</a>
          </div>
          <div class="grid gap-6 lg:grid-cols-3">
            <% cities.slice(0, 6).forEach(city => { %>
              <article class="overflow-hidden rounded-[1.75rem] border border-slate-200 bg-white shadow-sm">
                <a href="/cities/<%= city.slug %>" class="block">
                  <div class="h-52 bg-cover bg-center" style="background-image:url('<%= city.heroImage || '/images/placeholder.jpg' %>')"></div>
                </a>
                <div class="p-6">
                  <h3 class="text-xl font-semibold text-slate-900"><a href="/cities/<%= city.slug %>" class="hover:text-sky-600"><%= city.name %></a></h3>
                  <p class="mt-3 text-sm leading-6 text-slate-600"><%= city.summary || city.description?.slice(0, 120) || 'Explore the city’s best places and activities.' %></p>
                </div>
              </article>
            <% }) %>
          </div>
        </div>
      </section>

      <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="flex flex-col gap-4 md:items-start md:justify-between mb-6">
          <div>
            <p class="text-sm uppercase tracking-[0.28em] text-sky-600 font-semibold">Live experiences</p>
            <h2 class="mt-2 text-3xl font-semibold text-slate-900">Attractions and activities</h2>
          </div>
        </div>
        <div class="grid gap-6 xl:grid-cols-2">
          <div class="space-y-4">
            <% attractions.slice(0, 6).forEach(item => { %>
              <a href="/attractions/<%= item.slug %>" class="block rounded-[1.5rem] border border-slate-200 bg-white p-5 text-slate-900 transition hover:bg-slate-50">
                <strong class="text-lg font-semibold"><%= item.name %></strong>
                <span class="mt-2 block text-sm text-slate-600"><%= item.category || 'Attraction' %></span>
              </a>
            <% }) %>
          </div>
          <div class="space-y-4">
            <% activities.slice(0, 6).forEach(item => { %>
              <a href="/activities/<%= item.slug %>" class="block rounded-[1.5rem] border border-slate-200 bg-white p-5 text-slate-900 transition hover:bg-slate-50">
                <strong class="text-lg font-semibold"><%= item.name %></strong>
                <span class="mt-2 block text-sm text-slate-600"><%= item.category || 'Activity' %></span>
              </a>
            <% }) %>
          </div>
        </div>
      </section>
    </main>
    <%- include('partials/footer') %>
  </body>
</html>
