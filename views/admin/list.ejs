<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('../partials/head') %>
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <header class="mb-8 flex flex-col gap-4 rounded-[2rem] bg-white border border-slate-200 p-8 shadow-sm sm:flex-row sm:items-center sm:justify-between">
        <div>
          <h1 class="text-3xl font-semibold text-slate-900"><%= entityLabel %>s</h1>
          <p class="mt-2 text-slate-600">Ordered by priority and latest updates.</p>
        </div>
        <div class="flex flex-wrap gap-3">
          <a class="inline-flex rounded-2xl bg-sky-600 px-5 py-3 text-sm font-semibold text-white transition hover:bg-sky-700" href="/admin/<%= entity %>/new">Add new</a>
          <a class="inline-flex rounded-2xl border border-slate-300 bg-white px-5 py-3 text-sm font-semibold text-slate-900 transition hover:bg-slate-50" href="/admin">Dashboard</a>
        </div>
      </header>
      <form class="mb-6 flex flex-col gap-3 rounded-[1.75rem] border border-slate-200 bg-white p-6 shadow-sm sm:flex-row sm:items-center" action="/admin/<%= entity %>" method="GET">
        <label class="sr-only" for="search">Search</label>
        <input id="search" name="search" type="search" value="<%= search %>" placeholder="Search <%= entityLabel.toLowerCase() %>" class="w-full rounded-full border border-slate-300 bg-slate-50 px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-sky-500 focus:bg-white focus:ring-2 focus:ring-sky-100" />
        <button type="submit" class="inline-flex shrink-0 rounded-full bg-sky-600 px-6 py-3 text-sm font-semibold text-white transition hover:bg-sky-700">Search</button>
      </form>
      <% if (!items.length) { %>
        <div class="rounded-[1.75rem] border border-dashed border-slate-300 bg-white p-10 text-center text-slate-600">No <%= entityLabel.toLowerCase() %> entries found yet.</div>
      <% } else { %>
        <div class="overflow-hidden rounded-[1.75rem] border border-slate-200 bg-white shadow-sm">
          <table class="min-w-full divide-y divide-slate-200 text-left text-sm">
            <thead class="bg-slate-50">
              <tr>
                <th class="px-6 py-4 font-semibold text-slate-900">Name</th>
                <th class="px-6 py-4 font-semibold text-slate-900">Slug</th>
                <th class="px-6 py-4 font-semibold text-slate-900">Priority</th>
                <th class="px-6 py-4 font-semibold text-slate-900">Updated</th>
                <th class="px-6 py-4 font-semibold text-slate-900">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-200 bg-white">
              <% items.forEach(item => { %>
                <tr>
                  <td class="px-6 py-4 text-slate-900"><%= item.name %></td>
                  <td class="px-6 py-4 text-slate-600"><%= item.slug %></td>
                  <td class="px-6 py-4 text-slate-600"><%= item.priority %></td>
                  <td class="px-6 py-4 text-slate-600"><%= new Date(item.updatedAt).toLocaleString() %></td>
                  <td class="px-6 py-4 space-x-2">
                    <a class="inline-flex rounded-2xl border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-900 transition hover:bg-slate-50" href="/admin/<%= entity %>/<%= item._id %>/edit">Edit</a>
                    <form class="inline-block" action="/admin/<%= entity %>/<%= item._id %>/delete" method="POST" onsubmit="return confirm('Delete this item?');">
                      <button class="inline-flex rounded-2xl bg-red-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-red-700" type="submit">Delete</button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <%- include('../partials/pagination', { pagination }) %>
      <% } %>
    </div>
  </body>
</html>
