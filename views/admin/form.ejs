<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('../partials/head') %>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tom-select@2.4.3/dist/css/tom-select.css">
    <link href="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.snow.css" rel="stylesheet">
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-900">
    <%
      const selected = selectedReferences || {};
      const renderSelectedOptions = (items = []) => items.map((item) => `<option value="${item._id || item.value}" selected>${item.name || item.text}</option>`).join('');
      const guide = record.bestTimeToVisitGuide || {};
      const seasonDefaults = [
        { name: 'Spring', subtitle: 'The Awakening' },
        { name: 'Summer', subtitle: 'The Pulse' },
        { name: 'Autumn', subtitle: 'The Ember' },
        { name: 'Winter', subtitle: 'The Stillness' }
      ];
      const seasons = seasonDefaults.map((season, index) => {
        const existingSeason = Array.isArray(guide.seasons) ? guide.seasons[index] || {} : {};
        const highlightsValue = Array.isArray(existingSeason.highlights) ? existingSeason.highlights.join('\n') : existingSeason.highlights || '';
        return {
          ...season,
          ...existingSeason,
          highlightsValue
        };
      });
      const travelerProfileDefaults = [
        { title: 'The Newcomer' },
        { title: 'The Purist' }
      ];
      const travelerProfiles = travelerProfileDefaults.map((profile, index) => ({
        ...profile,
        ...(Array.isArray(guide.travelerProfiles) ? guide.travelerProfiles[index] || {} : {})
      }));
      const supportsBestTimeGuide = entity === 'countries' || entity === 'states' || entity === 'cities';
      const hotelGuide = record.hotelGuide || {};
      const hotelCards = Array.from({ length: 6 }, (_, index) => {
        const existingHotel = Array.isArray(hotelGuide.hotels) ? hotelGuide.hotels[index] || {} : {};
        const featuresValue = Array.isArray(existingHotel.features) ? existingHotel.features.join('\n') : existingHotel.features || '';
        return { ...existingHotel, featuresValue };
      });
      const supportsHotelGuide = entity === 'states' || entity === 'cities';
      const reachGuide = record.howToReachGuide || {};
      const reachSectionDefaults = [
        { eyebrow: '01 - AIR TRAVEL', title: 'By Air' },
        { eyebrow: '02 - RAILWAY', title: 'By Rail' },
        { eyebrow: '03 - ROAD & TAXI', title: 'By Road' }
      ];
      const reachSections = reachSectionDefaults.map((section, index) => {
        const existingSection = Array.isArray(reachGuide.sections) ? reachGuide.sections[index] || {} : {};
        const items = Array.from({ length: 3 }, (_, itemIndex) => ({
          ...(Array.isArray(existingSection.items) ? existingSection.items[itemIndex] || {} : {})
        }));
        return { ...section, ...existingSection, items };
      });
      const supportsReachGuide = entity === 'countries' || entity === 'states' || entity === 'cities';
      const blogCategories = Array.isArray(record.categories) ? record.categories : [];
      const attractionExpectItems = Array.from({ length: 4 }, (_, index) => ({
        ...(Array.isArray(record.expectItems) ? record.expectItems[index] || {} : {})
      }));
      const attractionGalleryImages = Array.isArray(record.galleryImages) ? record.galleryImages.join('\n') : '';
      const packageItineraryDays = Array.from({ length: 6 }, (_, index) => ({
        ...(Array.isArray(record.itineraryDays) ? record.itineraryDays[index] || {} : {})
      }));
      const packagePricingTiers = Array.from({ length: 3 }, (_, index) => ({
        ...(Array.isArray(record.pricingTiers) ? record.pricingTiers[index] || {} : {}),
        featuresValue: Array.isArray(record.pricingTiers?.[index]?.features) ? record.pricingTiers[index].features.join('\n') : record.pricingTiers?.[index]?.features || '',
        isFeatured: Boolean(record.pricingTiers?.[index]?.isFeatured)
      }));
      const packageReviews = Array.from({ length: 3 }, (_, index) => ({
        ...(Array.isArray(record.reviews) ? record.reviews[index] || {} : {})
      }));
    %>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <header class="mb-8 flex flex-col gap-4 rounded-[2rem] bg-white border border-slate-200 p-8 shadow-sm sm:flex-row sm:items-center sm:justify-between">
        <div>
          <h1 class="text-3xl font-semibold text-slate-900"><%= record && record._id ? 'Edit' : 'Create' %> <%= entityLabel %></h1>
          <p class="mt-2 text-slate-600">Set the priority, slug, and all dynamic fields for this entry.</p>
        </div>
        <a class="inline-flex rounded-2xl border border-slate-300 bg-white px-5 py-3 text-sm font-semibold text-slate-900 transition hover:bg-slate-50" href="/admin/<%= entity %>">Back</a>
      </header>
      <% if (error) { %>
        <div class="mb-6 rounded-2xl bg-red-50 px-4 py-4 text-sm text-red-700 ring-1 ring-red-200"><%= error %></div>
      <% } %>
      <form class="space-y-8 rounded-[2rem] bg-white border border-slate-200 p-8 shadow-sm" action="<%= action %>" method="POST" enctype="multipart/form-data">
        <div class="grid gap-6 xl:grid-cols-2">
          <label class="block">
            <span class="text-sm font-medium text-slate-700"><%= entity === 'blogs' ? 'Title' : 'Name' %></span>
            <input name="name" required value="<%= record.name || '' %>" class="mt-2 w-full rounded-2xl border border-slate-300 bg-slate-50 px-4 py-3 text-slate-900 outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100" />
          </label>
          <label class="block">
            <span class="text-sm font-medium text-slate-700">Slug</span>
            <input name="slug" value="<%= record.slug || '' %>" placeholder="auto-generated if blank" class="mt-2 w-full rounded-2xl border border-slate-300 bg-slate-50 px-4 py-3 text-slate-900 outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100" />
          </label>
          <label class="block">
            <span class="text-sm font-medium text-slate-700">Priority</span>
            <input name="priority" type="number" min="1" max="9999" value="<%= record.priority || 9999 %>" class="mt-2 w-full rounded-2xl border border-slate-300 bg-slate-50 px-4 py-3 text-slate-900 outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100" />
          </label>
          <label class="block">
            <span class="text-sm font-medium text-slate-700">Upload hero image</span>
            <input type="file" name="heroImageFile" accept="image/*" class="mt-2 w-full rounded-2xl border border-slate-300 bg-slate-50 px-4 py-3 text-slate-900 outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100" />
            <p class="mt-2 text-sm text-slate-500">Optional. Uploading a file will override the hero image URL.</p>
          </label>
          <label class="block">
            <span class="text-sm font-medium text-slate-700">Hero image URL</span>
            <input name="heroImageUrl" value="<%= record.heroImage || '' %>" class="mt-2 w-full rounded-2xl border border-slate-300 bg-slate-50 px-4 py-3 text-slate-900 outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100" />
          </label>
        </div>
        <% if (entity === 'packages') { %>
          <section class="space-y-8 rounded-[2rem] border border-slate-200 bg-slate-50 p-6 sm:p-8">
            <div>
              <h2 class="text-2xl font-semibold text-slate-900">Package Details Page Builder</h2>
              <p class="mt-2 text-sm leading-7 text-slate-600">These fields map to the stitched package details layout, including the hero, intro, itinerary timeline, pricing tiers, inclusions, and reviews.</p>
            </div>

            <div class="grid gap-6 xl:grid-cols-2">
              <label class="block">
                <span class="text-sm font-medium text-slate-700">Hero eyebrow</span>
                <input name="heroEyebrow" value="<%= record.heroEyebrow || '' %>" placeholder="7-Day Curated Expedition" class="mt-2 w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-900 outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100" />
              </label>
              <label class="block">
                <span class="text-sm font-medium text-slate-700">Hero location line</span>
                <input name="heroLocation" value="<%= record.heroLocation || '' %>" placeholder="Delhi • Agra • Jaipur" class="mt-2 w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-900 outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100" />
              </label>
              <label class="block">
                <span class="text-sm font-medium text-slate-700">Season label</span>
                <input name="heroSeason" value="<%= record.heroSeason || '' %>" placeholder="All Year Round" class="mt-2 w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-900 outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100" />
              </label>
              <label class="block">
                <span class="text-sm font-medium text-slate-700">Duration</span>
                <input name="duration" value="<%= record.duration || '' %>" placeholder="7 Days" class="mt-2 w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-900 outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100" />
              </label>
              <label class="block">
                <span class="text-sm font-medium text-slate-700">Starting price</span>
                <input name="price" value="<%= record.price || '' %>" placeholder="$899" class="mt-2 w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-900 outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100" />
              </label>
              <label class="block">
                <span class="text-sm font-medium text-slate-700">Floating price label</span>
                <input name="bookingPriceLabel" value="<%= record.bookingPriceLabel || '' %>" placeholder="/ traveler" class="mt-2 w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-900 outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100" />
              </label>
              <label class="block xl:col-span-2">
                <span class="text-sm font-medium text-slate-700">Intro heading</span>
                <input name="introHeading" value="<%= record.introHeading || '' %>" class="mt-2 w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-900 outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100" />
              </label>
              <label class="block xl:col-span-2">
                <span class="text-sm font-medium text-slate-700">Intro body</span>
                <textarea rows="5" name="introBody" class="mt-2 w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-900 outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100"><%= record.introBody || '' %></textarea>
              </label>
              <label class="block">
                <span class="text-sm font-medium text-slate-700">Intro side image URL</span>
                <input name="introImage" value="<%= record.introImage || '' %>" class="mt-2 w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-900 outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100" />
              </label>
              <label class="block">
                <span class="text-sm font-medium text-slate-700">Testimonial author</span>
                <input name="testimonialAuthor" value="<%= record.testimonialAuthor || '' %>" placeholder="Elena V., Travel Journalist" class="mt-2 w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-900 outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100" />
              </label>
              <label class="block xl:col-span-2">
                <span class="text-sm font-medium text-slate-700">Testimonial quote</span>
                <textarea rows="3" name="testimonialQuote" class="mt-2 w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-900 outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100"><%= record.testimonialQuote || '' %></textarea>
              </label>
            </div>

            <div class="grid gap-6 lg:grid-cols-2">
              <label class="block">
                <span class="text-sm font-medium text-slate-700">Itinerary countries</span>
                <select name="itineraryCountries" multiple data-remote-entity="countries" data-placeholder="Search countries" class="js-remote-select mt-2 w-full">
                  <%- renderSelectedOptions(selected.countries) %>
                </select>
              </label>
              <label class="block">
                <span class="text-sm font-medium text-slate-700">Itinerary states</span>
                <select name="itineraryStates" multiple data-remote-entity="states" data-placeholder="Search states" class="js-remote-select mt-2 w-full">
                  <%- renderSelectedOptions(selected.states) %>
                </select>
              </label>
              <label class="block">
                <span class="text-sm font-medium text-slate-700">Itinerary cities</span>
                <select name="itineraryCities" multiple data-remote-entity="cities" data-placeholder="Search cities" class="js-remote-select mt-2 w-full">
                  <%- renderSelectedOptions(selected.cities) %>
                </select>
              </label>
              <label class="block">
                <span class="text-sm font-medium text-slate-700">Itinerary attractions</span>
                <select name="itineraryAttractions" multiple data-remote-entity="attractions" data-placeholder="Search attractions" class="js-remote-select mt-2 w-full">
                  <%- renderSelectedOptions(selected.attractions) %>
                </select>
              </label>
            </div>
            <label class="block">
              <span class="text-sm font-medium text-slate-700">Itinerary activities</span>
              <select name="itineraryActivities" multiple data-remote-entity="activities" data-placeholder="Search activities" class="js-remote-select mt-2 w-full">
                <%- renderSelectedOptions(selected.activities) %>
              </select>
            </label>

            <div class="space-y-6">
              <div>
                <h3 class="text-xl font-semibold text-slate-900">Itinerary Timeline</h3>
                <p class="mt-2 text-sm text-slate-500">Add the day cards used in the vertical itinerary section.</p>
              </div>
              <% packageItineraryDays.forEach((day, index) => { %>
                <div class="grid gap-4 rounded-[1.75rem] border border-slate-200 bg-white p-5 xl:grid-cols-3">
                  <label class="block">
                    <span class="text-sm font-medium text-slate-700">Day label</span>
                    <input name="itineraryDays[<%= index %>][dayLabel]" value="<%= day.dayLabel || '' %>" placeholder="Day 1 / Arrival & Immersion" class="mt-2 w-full rounded-2xl border border-slate-300 bg-slate-50 px-4 py-3 text-slate-900 outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100" />
                  </label>
                  <label class="block">
                    <span class="text-sm font-medium text-slate-700">Title</span>
                    <input name="itineraryDays[<%= index %>][title]" value="<%= day.title || '' %>" class="mt-2 w-full rounded-2xl border border-slate-300 bg-slate-50 px-4 py-3 text-slate-900 outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100" />
                  </label>
                  <label class="block xl:col-span-3">
                    <span class="text-sm font-medium text-slate-700">Description</span>
                    <textarea rows="3" name="itineraryDays[<%= index %>][description]" class="mt-2 w-full rounded-2xl border border-slate-300 bg-slate-50 px-4 py-3 text-slate-900 outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100"><%= day.description || '' %></textarea>
                  </label>
                </div>
              <% }) %>
            </div>

            <div class="space-y-6">
              <div>
                <h3 class="text-xl font-semibold text-slate-900">Pricing Tiers</h3>
                <p class="mt-2 text-sm text-slate-500">Each tier powers one pricing card. Put one feature per line.</p>
              </div>
              <div class="grid gap-6 xl:grid-cols-3">
                <% packagePricingTiers.forEach((tier, index) => { %>
                  <section class="rounded-[1.75rem] border border-slate-200 bg-white p-6">
                    <h4 class="text-lg font-semibold text-slate-900">Tier <%= index + 1 %></h4>
                    <div class="mt-5 space-y-4">
                      <label class="block">
                        <span class="text-sm font-medium text-slate-700">Eyebrow</span>
                        <input name="pricingTiers[<%= index %>][eyebrow]" value="<%= tier.eyebrow || '' %>" placeholder="The Explorer" class="mt-2 w-full rounded-2xl border border-slate-300 bg-slate-50 px-4 py-3 text-slate-900 outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100" />
                      </label>
                      <label class="block">
                        <span class="text-sm font-medium text-slate-700">Tier name</span>
                        <input name="pricingTiers[<%= index %>][name]" value="<%= tier.name || '' %>" placeholder="Budget" class="mt-2 w-full rounded-2xl border border-slate-300 bg-slate-50 px-4 py-3 text-slate-900 outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100" />
                      </label>
                      <label class="block">
                        <span class="text-sm font-medium text-slate-700">Tier price</span>
                        <input name="pricingTiers[<%= index %>][price]" value="<%= tier.price || '' %>" placeholder="$899" class="mt-2 w-full rounded-2xl border border-slate-300 bg-slate-50 px-4 py-3 text-slate-900 outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100" />
                      </label>
                      <label class="block">
                        <span class="text-sm font-medium text-slate-700">Price suffix</span>
                        <input name="pricingTiers[<%= index %>][priceSuffix]" value="<%= tier.priceSuffix || '' %>" placeholder="/ person" class="mt-2 w-full rounded-2xl border border-slate-300 bg-slate-50 px-4 py-3 text-slate-900 outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100" />
                      </label>
                      <label class="block">
                        <span class="text-sm font-medium text-slate-700">Button label</span>
                        <input name="pricingTiers[<%= index %>][buttonLabel]" value="<%= tier.buttonLabel || '' %>" placeholder="Inquire Now" class="mt-2 w-full rounded-2xl border border-slate-300 bg-slate-50 px-4 py-3 text-slate-900 outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100" />
                      </label>
                      <label class="flex items-center gap-3 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3">
                        <input type="checkbox" name="pricingTiers[<%= index %>][isFeatured]" value="true" <%= tier.isFeatured ? 'checked' : '' %> class="h-4 w-4 rounded border-slate-300 text-sky-600 focus:ring-sky-500" />
                        <span class="text-sm font-medium text-slate-700">Highlight this tier</span>
                      </label>
                      <label class="block">
                        <span class="text-sm font-medium text-slate-700">Features</span>
                        <textarea rows="5" name="pricingTiers[<%= index %>][features]" class="mt-2 w-full rounded-2xl border border-slate-300 bg-slate-50 px-4 py-3 text-slate-900 outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100"><%= tier.featuresValue || '' %></textarea>
                      </label>
                    </div>
                  </section>
                <% }) %>
              </div>
            </div>

            <div class="grid gap-6 xl:grid-cols-2">
              <label class="block">
                <span class="text-sm font-medium text-slate-700">Pricing section heading</span>
                <input name="pricingHeading" value="<%= record.pricingHeading || '' %>" placeholder="Choose Your Experience Level" class="mt-2 w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-900 outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100" />
              </label>
              <label class="block">
                <span class="text-sm font-medium text-slate-700">Primary booking button label</span>
                <input name="bookingButtonLabel" value="<%= record.bookingButtonLabel || '' %>" placeholder="Book Now" class="mt-2 w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-900 outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100" />
              </label>
              <label class="block xl:col-span-2">
                <span class="text-sm font-medium text-slate-700">Pricing section description</span>
                <textarea rows="3" name="pricingDescription" class="mt-2 w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-900 outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100"><%= record.pricingDescription || '' %></textarea>
              </label>
              <label class="block xl:col-span-2">
                <span class="text-sm font-medium text-slate-700">Secondary booking button label</span>
                <input name="bookingSecondaryLabel" value="<%= record.bookingSecondaryLabel || '' %>" placeholder="Save to Itinerary" class="mt-2 w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-900 outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100" />
              </label>
            </div>

            <div class="grid gap-6 xl:grid-cols-2">
              <label class="block">
                <span class="text-sm font-medium text-slate-700">What's included</span>
                <textarea rows="6" name="inclusions" class="mt-2 w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-900 outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100"><%= Array.isArray(record.inclusions) ? record.inclusions.join('\n') : '' %></textarea>
              </label>
              <label class="block">
                <span class="text-sm font-medium text-slate-700">What's excluded</span>
                <textarea rows="6" name="exclusions" class="mt-2 w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-900 outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100"><%= Array.isArray(record.exclusions) ? record.exclusions.join('\n') : '' %></textarea>
              </label>
            </div>

            <div class="space-y-6">
              <div>
                <h3 class="text-xl font-semibold text-slate-900">Traveler Reviews</h3>
                <p class="mt-2 text-sm text-slate-500">Add the review cards displayed near the end of the package page.</p>
              </div>
              <div class="grid gap-6 xl:grid-cols-3">
                <% packageReviews.forEach((review, index) => { %>
                  <section class="rounded-[1.75rem] border border-slate-200 bg-white p-6">
                    <h4 class="text-lg font-semibold text-slate-900">Review <%= index + 1 %></h4>
                    <div class="mt-5 space-y-4">
                      <label class="block">
                        <span class="text-sm font-medium text-slate-700">Traveler name</span>
                        <input name="reviews[<%= index %>][name]" value="<%= review.name || '' %>" class="mt-2 w-full rounded-2xl border border-slate-300 bg-slate-50 px-4 py-3 text-slate-900 outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100" />
                      </label>
                      <label class="block">
                        <span class="text-sm font-medium text-slate-700">Meta line</span>
                        <input name="reviews[<%= index %>][meta]" value="<%= review.meta || '' %>" placeholder="Visited Nov 2023" class="mt-2 w-full rounded-2xl border border-slate-300 bg-slate-50 px-4 py-3 text-slate-900 outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100" />
                      </label>
                      <label class="block">
                        <span class="text-sm font-medium text-slate-700">Image URL</span>
                        <input name="reviews[<%= index %>][image]" value="<%= review.image || '' %>" class="mt-2 w-full rounded-2xl border border-slate-300 bg-slate-50 px-4 py-3 text-slate-900 outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100" />
                      </label>
                      <label class="block">
                        <span class="text-sm font-medium text-slate-700">Quote</span>
                        <textarea rows="4" name="reviews[<%= index %>][quote]" class="mt-2 w-full rounded-2xl border border-slate-300 bg-slate-50 px-4 py-3 text-slate-900 outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100"><%= review.quote || '' %></textarea>
                      </label>
                    </div>
                  </section>
                <% }) %>
              </div>
            </div>
          </section>
        <% } %>
        <% if (entity === 'states' || entity === 'cities' || entity === 'attractions' || entity === 'activities' || entity === 'hotels') { %>
          <div class="grid gap-6 xl:grid-cols-2">
            <label class="block">
              <span class="text-sm font-medium text-slate-700">Country</span>
