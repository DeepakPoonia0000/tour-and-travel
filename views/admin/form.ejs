                <input name="hotelGuide[tagTwo]" value="<%= hotelGuide.tagTwo || '' %>" class="mt-2 w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-900 outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100" />
              </label>
              <label class="block">
                <span class="text-sm font-medium text-slate-700">Tag 3</span>
                <input name="hotelGuide[tagThree]" value="<%= hotelGuide.tagThree || '' %>" class="mt-2 w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-900 outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100" />
              </label>
            </div>
            <div class="space-y-6">
              <% hotelCards.forEach((hotel, hotelIndex) => { %>
                <section class="rounded-[1.75rem] border border-slate-200 bg-white p-6">
                  <h3 class="text-lg font-semibold text-slate-900">Hotel Card <%= hotelIndex + 1 %></h3>
                  <div class="mt-5 grid gap-6 xl:grid-cols-2">
                    <label class="block">
                      <span class="text-sm font-medium text-slate-700">Area / neighborhood</span>
                      <input name="hotelGuide[hotels][<%= hotelIndex %>][area]" value="<%= hotel.area || '' %>" class="mt-2 w-full rounded-2xl border border-slate-300 bg-slate-50 px-4 py-3 text-slate-900 outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100" />
                    </label>
                    <label class="block">
                      <span class="text-sm font-medium text-slate-700">Hotel name</span>
                      <input name="hotelGuide[hotels][<%= hotelIndex %>][name]" value="<%= hotel.name || '' %>" class="mt-2 w-full rounded-2xl border border-slate-300 bg-slate-50 px-4 py-3 text-slate-900 outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100" />
                    </label>
                    <label class="block">
                      <span class="text-sm font-medium text-slate-700">Image URL</span>
                      <input name="hotelGuide[hotels][<%= hotelIndex %>][image]" value="<%= hotel.image || '' %>" class="mt-2 w-full rounded-2xl border border-slate-300 bg-slate-50 px-4 py-3 text-slate-900 outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100" />
                    </label>
                    <label class="block">
                      <span class="text-sm font-medium text-slate-700">Image alt text</span>
                      <input name="hotelGuide[hotels][<%= hotelIndex %>][imageAlt]" value="<%= hotel.imageAlt || '' %>" class="mt-2 w-full rounded-2xl border border-slate-300 bg-slate-50 px-4 py-3 text-slate-900 outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100" />
                    </label>
                    <label class="block">
                      <span class="text-sm font-medium text-slate-700">Rating</span>
                      <input name="hotelGuide[hotels][<%= hotelIndex %>][rating]" value="<%= hotel.rating || '' %>" placeholder="4.9" class="mt-2 w-full rounded-2xl border border-slate-300 bg-slate-50 px-4 py-3 text-slate-900 outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100" />
                    </label>
                    <label class="block">
                      <span class="text-sm font-medium text-slate-700">Starting price</span>
                      <input name="hotelGuide[hotels][<%= hotelIndex %>][price]" value="<%= hotel.price || '' %>" placeholder="$890 / night" class="mt-2 w-full rounded-2xl border border-slate-300 bg-slate-50 px-4 py-3 text-slate-900 outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100" />
                    </label>
                    <label class="block xl:col-span-2">
                      <span class="text-sm font-medium text-slate-700">Features</span>
                      <textarea rows="4" name="hotelGuide[hotels][<%= hotelIndex %>][features]" class="mt-2 w-full rounded-2xl border border-slate-300 bg-slate-50 px-4 py-3 text-slate-900 outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100"><%= hotel.featuresValue || '' %></textarea>
                    </label>
                  </div>
                </section>
              <% }) %>
            </div>
            <div class="grid gap-6 xl:grid-cols-2">
              <label class="block">
                <span class="text-sm font-medium text-slate-700">Newsletter section title</span>
                <input name="hotelGuide[newsletterTitle]" value="<%= hotelGuide.newsletterTitle || '' %>" class="mt-2 w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-900 outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100" />
              </label>
              <label class="block">
                <span class="text-sm font-medium text-slate-700">Newsletter section text</span>
                <textarea rows="3" name="hotelGuide[newsletterText]" class="mt-2 w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-900 outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100"><%= hotelGuide.newsletterText || '' %></textarea>
              </label>
            </div>
          </section>
        <% } %>
        <div class="grid gap-6 xl:grid-cols-2">
          <label class="block">
            <span class="text-sm font-medium text-slate-700">SEO title</span>
            <input name="seoTitle" value="<%= record.seoTitle || '' %>" class="mt-2 w-full rounded-2xl border border-slate-300 bg-slate-50 px-4 py-3 text-slate-900 outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100" />
          </label>
          <label class="block">
            <span class="text-sm font-medium text-slate-700">SEO description</span>
            <textarea rows="3" name="seoDescription" class="mt-2 w-full rounded-2xl border border-slate-300 bg-slate-50 px-4 py-3 text-slate-900 outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100"><%= record.seoDescription || '' %></textarea>
          </label>
        </div>
        <label class="block">
          <span class="text-sm font-medium text-slate-700">SEO keywords</span>
          <input name="seoKeywords" value="<%= record.seoKeywords || '' %>" class="mt-2 w-full rounded-2xl border border-slate-300 bg-slate-50 px-4 py-3 text-slate-900 outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-100" />
        </label>
        <button class="w-full rounded-2xl bg-sky-600 px-6 py-4 text-base font-semibold text-white transition hover:bg-sky-700" type="submit"><%= record && record._id ? 'Update' : 'Create' %> <%= entityLabel %></button>
      </form>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/tom-select@2.4.3/dist/js/tom-select.complete.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.min.js"></script>
    <script>
      (() => {
        const buildUrl = (select, query) => {
          const url = new URL(`/admin/api/options/${select.dataset.remoteEntity}`, window.location.origin);
          if (query) url.searchParams.set('q', query);
          const parentCountry = select.dataset.parentCountry && document.querySelector(`[name="${select.dataset.parentCountry}"]`)?.value;
          const parentState = select.dataset.parentState && document.querySelector(`[name="${select.dataset.parentState}"]`)?.value;
          if (parentCountry) url.searchParams.set('countryId', parentCountry);
          if (parentState) url.searchParams.set('stateId', parentState);
          return url.toString();
        };

        const instances = [];

        document.querySelectorAll('.js-remote-select').forEach((select) => {
          const instance = new TomSelect(select, {
            valueField: 'value',
            labelField: 'text',
            searchField: ['text', 'meta'],
            plugins: select.multiple ? ['remove_button'] : [],
            create: false,
            maxOptions: 15,
            preload: 'focus',
            placeholder: select.dataset.placeholder || 'Search',
            load: function(query, callback) {
              fetch(buildUrl(select, query))
                .then((res) => res.json())
                .then((data) => callback(data.items || []))
                .catch(() => callback());
            }
          });
          instances.push({ select, instance });
        });

        document.querySelectorAll('.js-tag-select').forEach((select) => {
          new TomSelect(select, {
            plugins: ['remove_button'],
            persist: false,
            create: true,
            placeholder: select.dataset.placeholder || 'Add tags'
          });
        });

        const resetDependent = (name) => {
          const target = instances.find((entry) => entry.select.name === name);
          if (!target) return;
          target.instance.clear(true);
          target.instance.clearOptions();
        };

        const country = document.querySelector('[name="country"]');
        const state = document.querySelector('[name="state"]');
        if (country) country.addEventListener('change', () => {
          resetDependent('state');
          resetDependent('city');
        });
        if (state) state.addEventListener('change', () => {
          resetDependent('city');
        });

        const editorRoot = document.getElementById('blog-editor');
        const contentInput = document.getElementById('blog-content-input');
        if (editorRoot && contentInput) {
          const quill = new Quill(editorRoot, {
            theme: 'snow',
            modules: {
              toolbar: [
                [{ header: [2, 3, false] }],
                ['bold', 'italic', 'underline', 'blockquote'],
                [{ list: 'ordered' }, { list: 'bullet' }],
                ['link'],
                ['clean']
              ]
            }
          });
          quill.root.innerHTML = contentInput.value || '';
          quill.on('text-change', () => {
            contentInput.value = quill.root.innerHTML;
          });
        }
      })();
    </script>
  </body>
</html>
