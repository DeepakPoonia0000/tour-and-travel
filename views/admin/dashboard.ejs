<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('../partials/head') %>
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <header class="mb-10 flex flex-col gap-4 rounded-[2rem] bg-white border border-slate-200 p-8 shadow-sm sm:flex-row sm:items-center sm:justify-between">
        <div>
          <h1 class="text-3xl font-semibold text-slate-900">Admin Dashboard</h1>
          <p class="mt-2 text-slate-600">Manage countries, states, cities, attractions and activities.</p>
        </div>
        <form action="/admin/logout" method="POST">
          <button class="rounded-2xl bg-slate-900 px-5 py-3 text-sm font-semibold text-white transition hover:bg-slate-800" type="submit">Logout</button>
        </form>
      </header>
      <main class="grid gap-6 sm:grid-cols-2 xl:grid-cols-3">
        <article class="rounded-[1.75rem] border border-slate-200 bg-white p-8 shadow-sm">
          <h2 class="text-xl font-semibold text-slate-900">Countries</h2>
          <p class="mt-3 text-slate-600"><%= counts.countries %> entries</p>
          <a class="mt-6 inline-flex rounded-2xl bg-sky-600 px-5 py-3 text-sm font-semibold text-white transition hover:bg-sky-700" href="/admin/countries">Manage</a>
        </article>
        <article class="rounded-[1.75rem] border border-slate-200 bg-white p-8 shadow-sm">
          <h2 class="text-xl font-semibold text-slate-900">States</h2>
          <p class="mt-3 text-slate-600"><%= counts.states %> entries</p>
          <a class="mt-6 inline-flex rounded-2xl bg-sky-600 px-5 py-3 text-sm font-semibold text-white transition hover:bg-sky-700" href="/admin/states">Manage</a>
        </article>
        <article class="rounded-[1.75rem] border border-slate-200 bg-white p-8 shadow-sm">
          <h2 class="text-xl font-semibold text-slate-900">Cities</h2>
          <p class="mt-3 text-slate-600"><%= counts.cities %> entries</p>
          <a class="mt-6 inline-flex rounded-2xl bg-sky-600 px-5 py-3 text-sm font-semibold text-white transition hover:bg-sky-700" href="/admin/cities">Manage</a>
        </article>
        <article class="rounded-[1.75rem] border border-slate-200 bg-white p-8 shadow-sm">
          <h2 class="text-xl font-semibold text-slate-900">Attractions</h2>
          <p class="mt-3 text-slate-600"><%= counts.attractions %> entries</p>
          <a class="mt-6 inline-flex rounded-2xl bg-sky-600 px-5 py-3 text-sm font-semibold text-white transition hover:bg-sky-700" href="/admin/attractions">Manage</a>
        </article>
        <article class="rounded-[1.75rem] border border-slate-200 bg-white p-8 shadow-sm">
          <h2 class="text-xl font-semibold text-slate-900">Activities</h2>
          <p class="mt-3 text-slate-600"><%= counts.activities %> entries</p>
          <a class="mt-6 inline-flex rounded-2xl bg-sky-600 px-5 py-3 text-sm font-semibold text-white transition hover:bg-sky-700" href="/admin/activities">Manage</a>
        </article>
        <article class="rounded-[1.75rem] border border-slate-200 bg-white p-8 shadow-sm">
          <h2 class="text-xl font-semibold text-slate-900">Packages</h2>
          <p class="mt-3 text-slate-600"><%= counts.packages %> entries</p>
          <a class="mt-6 inline-flex rounded-2xl bg-sky-600 px-5 py-3 text-sm font-semibold text-white transition hover:bg-sky-700" href="/admin/packages">Manage</a>
        </article>
      </main>
    </div>
  </body>
</html>
