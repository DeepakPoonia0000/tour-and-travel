<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('partials/head') %>
  </head>
  <body class="bg-background text-on-surface">
    <%- include('partials/header') %>
    <main class="pt-20">
      <header class="relative w-full h-[870px] overflow-hidden">
        <img alt="<%= blog.name %>" class="w-full h-full object-cover" src="<%= blog.heroImage || '/images/placeholder.jpg' %>"/>
        <div class="absolute inset-0 bg-gradient-to-t from-primary/80 via-transparent to-transparent"></div>
        <div class="absolute bottom-0 left-0 w-full p-8 md:p-16 max-w-7xl mx-auto">
          <div class="flex flex-col gap-4">
            <span class="inline-block px-4 py-1 bg-secondary text-white text-xs font-bold tracking-widest uppercase rounded-full self-start"><%= blog.primaryCategory || 'Journal' %></span>
            <h1 class="text-white text-5xl md:text-7xl font-black tracking-tighter max-w-4xl leading-[1.1]"><%= blog.name %></h1>
            <div class="flex flex-wrap items-center gap-6 text-white/90 font-medium">
              <% if (blog.authorName) { %><span><%= blog.authorName %></span><% } %>
              <% if (blog.publishedAt) { %><span><%= new Date(blog.publishedAt).toLocaleDateString() %></span><% } %>
              <% if (blog.readTime) { %><span><%= blog.readTime %></span><% } %>
            </div>
          </div>
        </div>
      </header>

      <article class="max-w-7xl mx-auto px-8 py-24 grid grid-cols-1 lg:grid-cols-12 gap-16">
        <div class="lg:col-span-8 space-y-12">
          <section class="space-y-8">
            <p class="text-xl md:text-2xl font-light text-slate-600 leading-relaxed"><%= blog.summary || blog.description %></p>
          </section>
          <section class="prose prose-slate max-w-none prose-headings:font-semibold prose-a:text-primary">
            <%- blog.content || `<p>${blog.description || ''}</p>` %>
          </section>
          <% if (blog.categories && blog.categories.length) { %>
            <div class="pt-16 border-t border-slate-200 flex flex-wrap justify-between items-center gap-8">
              <div class="flex gap-2 flex-wrap">
                <% blog.categories.forEach((category) => { %>
                  <span class="bg-slate-100 px-4 py-2 rounded-lg text-xs font-bold text-slate-600"><%= category %></span>
                <% }) %>
              </div>
            </div>
          <% } %>
        </div>
        <div class="lg:col-span-4 space-y-12">
          <div class="bg-slate-100 p-8 rounded-2xl space-y-6">
            <% if (blog.authorImage) { %><img alt="<%= blog.authorName || 'Author' %>" class="w-24 h-24 rounded-full object-cover" src="<%= blog.authorImage %>"/><% } %>
            <div>
              <h4 class="text-xl font-bold text-primary"><%= blog.authorName || 'Editorial Team' %></h4>
              <p class="text-sm text-slate-500 font-medium"><%= blog.authorRole || 'Contributor' %></p>
            </div>
            <p class="text-sm text-slate-600 leading-relaxed italic"><%= blog.authorBio || 'Add an author bio in admin to personalize this article.' %></p>
          </div>
        </div>
      </article>

      <% if (relatedBlogs && relatedBlogs.length) { %>
        <section class="bg-white py-24">
          <div class="max-w-7xl mx-auto px-8">
            <div class="flex justify-between items-end mb-12">
              <div class="space-y-2">
                <span class="text-secondary font-bold tracking-[0.2em] uppercase text-xs">Keep Exploring</span>
                <h3 class="text-4xl font-black text-primary">Related Stories</h3>
              </div>
              <a class="text-primary font-bold flex items-center gap-2 group" href="/blogs">See All Journal Entries</a>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
              <% relatedBlogs.forEach((item) => { %>
                <a href="/blogs/<%= item.slug %>" class="group block">
                  <div class="relative h-[300px] overflow-hidden rounded-2xl mb-6">
                    <img class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" src="<%= item.heroImage || blog.heroImage || '/images/placeholder.jpg' %>" alt="<%= item.name %>"/>
                  </div>
                  <h5 class="text-xl font-bold text-primary group-hover:text-secondary transition-colors leading-tight mb-2"><%= item.name %></h5>
                  <p class="text-sm text-slate-600 line-clamp-2"><%= item.summary || item.description || 'Read more.' %></p>
                </a>
              <% }) %>
            </div>
          </div>
        </section>
      <% } %>
    </main>
    <%- include('partials/footer') %>
  </body>
</html>
