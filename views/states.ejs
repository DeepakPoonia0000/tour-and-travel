<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('partials/head') %>
  </head>
  <body class="bg-slate-50 text-slate-950">
    <%- include('partials/header') %>
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <section class="rounded-[2rem] bg-white border border-slate-200 p-10 shadow-sm mb-10">
        <p class="text-sm uppercase tracking-[0.28em] text-secondary font-semibold">States & regions</p>
        <h1 class="mt-4 text-5xl font-serif font-semibold tracking-tight text-slate-950">Regional travel guides</h1>
        <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-600">State pages show linked cities, attractions, and activities sorted by priority and latest updates.</p>
      </section>
      <section>
        <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
          <% states.forEach(state => { %>
            <article class="overflow-hidden rounded-[2rem] bg-white shadow-xl transition duration-200 hover:-translate-y-1 hover:shadow-2xl">
              <a href="/states/<%= state.slug %>">
                <div class="h-72 bg-cover bg-center" style="background-image:url('<%= state.heroImage || 'https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&w=1200&q=80' %>')"></div>
              </a>
              <div class="p-8">
                <h3 class="text-2xl font-semibold text-slate-950"><a href="/states/<%= state.slug %>" class="hover:text-sky-600"><%= state.name %></a></h3>
                <p class="mt-4 text-sm leading-6 text-slate-600"><%= state.summary || state.description?.slice(0, 130) || 'Explore regional attractions and local culture.' %></p>
              </div>
            </article>
          <% }) %>
        </div>
      </section>
    </main>
    <%- include('partials/footer') %>
  </body>
</html>
